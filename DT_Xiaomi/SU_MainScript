    // Update is called once per frame
    float elapseTime = 0f;
	void Update () 
    {
        if (deleteTime > 0)
        {
            elapseTime += Time.deltaTime;
            if (elapseTime > deleteTime)
            {
                Label_Tip.Text = GameContext.GetInstance.localizedStringData.GetString(textNumToReturn);
                InitDeleteTime();
            }
        }
	}

    void InitDeleteTime() // 텍스트 자동수정 시간 리셋 함수
    {
        deleteTime = 0;
        elapseTime = 0;
    }
