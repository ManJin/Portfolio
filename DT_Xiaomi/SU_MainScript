    string MakePopupInfoString(int minLV, int maxLV) // '카드상점' : 1,2,3 부스터카드 구매 시 발생하는 팝업 내용 셋팅
    {
        int localnum = 1012;
        if (minLV == 1)
            localnum = 1012;
        else if (minLV == 2)
            localnum = 1039;
        else if (minLV == 3)
            localnum = 1040;
        StringBuilder sb = new StringBuilder("", 256);
        sb.Append(GameContext.GetInstance.localizedStringData.GetString(localnum));
        sb.Append("\n");
        sb.Append(GameContext.GetInstance.localizedStringData.GetString(1011));
        return sb.ToString();
    }

    void fn_ActiveMenu(dfControl[] Controls,string MenuName)
    {
        foreach (dfControl control in Controls)
        {
            if (control.name == MenuName)
            {
                //Debug.Log("MenuName : " + MenuName);
                control.Show();
            }
            else
            {
                //Debug.Log("MenuName : " + MenuName);
                control.Hide();
            }
        }
    }

