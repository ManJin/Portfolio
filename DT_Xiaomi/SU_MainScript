    uint selectEquipCardIdx;
    public void btn_FrontCard_clicked(uint cardBaseState, uint cardIdx) // '카드장착','카드공장','카드판매' 메뉴 활성화 중 '카드'클릭 시 진입
    {
#if UNITY_EDITOR
        Debug.Log((Clip_FrontfaceCard.CARDBASESTATE)cardBaseState + "," + cardIdx);
#endif
        GameContext.GetInstance.uiSoundPlayer.EffectSoundPlay(EffectSoundPlayer.UI_SOUND.OK);
        GameContext.GetInstance.uiSoundPlayer.EffectSoundPlay(EffectSoundPlayer.eCARD_SOUND.Tap_001);
        switch ((Clip_FrontfaceCard.CARDBASESTATE)cardBaseState)
        {
            case Clip_FrontfaceCard.CARDBASESTATE.EQUIP_BASE_VIEW:
                if (enableMenuChange == false)
                    return;
                //선택한 카드를 장착 칸으로 옮기고 장착효과를 주어야 함.
                selectEquipCardIdx = cardIdx;
                enableMenuChange = false;
                fn_SideMenuEnable(enableMenuChange);
                dfScrollPanel ScrollPanel = GameObject.Find("ScrollPanel_Equip").GetComponent<dfScrollPanel>();
                ScrollPanel.IsInteractive = false;
                CardBase cardToequip = CardSystemManager.GetInstance.GetCardFromInventory_ID(cardIdx);
                equipDecisionView.SetEquipCardFrontInfo(cardToequip, true);
                equipDecisionView.SetEquipCardEffectInfo(cardToequip);
                equipDecisionView.visible = true;
                break;

            case Clip_FrontfaceCard.CARDBASESTATE.EQUIP_SLOT_VIEW:
                if (enableMenuChange == false)
                    return;
                selectEquipCardIdx = cardIdx;
                invenCard_EquipBase.dragable = false;
                CardBase cardTorel = CardSystemManager.GetInstance.GetCardFromSlot((int)cardIdx);
                equipDecisionView.SetEquipCardFrontInfo(cardTorel, false);
                equipDecisionView.SetEquipCardEffectInfo(cardTorel);
                equipDecisionView.visible = true;
                break;

            case Clip_FrontfaceCard.CARDBASESTATE.COMP_BASE_VIEW:
                if (Clip_InvenCardBasePlate.IsCardSelectable(cardIdx))
                {
                    dfScrollPanel S_Panel_ScrollPanel_Comp = GameObject.Find("ScrollPanel_Comp").GetComponent<dfScrollPanel>(); // 카드선택용 스크롤 판넬 가져오기
                    S_Panel_ScrollPanel_Comp.Hide(); // 숨기기
                    dfPanel Panel_SelectCard = GameObject.Find("SelectCard").GetComponent<dfPanel>(); // 카드선택 판넬 가져오기
                    Panel_SelectCard.Show(); // 보이기
                    cardCompViewer.CardToCompoundSlot(cardIdx);
                }
                break;

            case Clip_FrontfaceCard.CARDBASESTATE.SELL_BASE_VIEW:
                if (enableMenuChange == false)
                    return;
                invenCard_SellBase.OnClicked_FrontCard(cardBaseState, cardIdx);
                break;
        }
    }

