    public void popget_cardFactory(dfControl control, dfMouseEventArgs mouseEvent) // '카드상점' : '부스터카드클릭' : '구매팝업' : '예 버튼 클릭 시 진입
    {
        CardGoods goods = cardShopBase.GetCardGoodsInfo((int)selectedPackageID);

        GameContext gc = GameContext.GetInstance;

        if (CardSystemManager.GetInstance.GetCardCntInInventory() == CardConsts.MAX_INVENTORYSLOT)
        {
            SetAutoDeleteTextInfo(SHOPINFOTXT, LACKINVEN, 2.5f);
            enableMenuChange = true;
            fn_SideMenuEnable(enableMenuChange);
            //cardShopBase.dragable = true;
            return;
        }

        if (GameContext.GetInstance.gameData.CrystalTransaction(TRANSACTION_TYPE.CARD_SYSTEM_PURCHASE, -goods.price))
        {
            int crystalPoint = GameContext.GetInstance.gameData.GetUserCrystal;
            Label_TotalCrystal.Text = crystalPoint.ToString();
            //카드구입
            Panel_MarketMenu[0].Hide();
            Panel_MarketPopup[0].Hide();
            Card_HiddenCard.Show();

            // 카드패키지 개봉
            CardBase makeCards = CardSystemManager.GetInstance.CreateRandomCard((CardSystemManager.CARD_CREATION_FLAG)(goods.id - 1001));

            if (makeCards != null)
            {
                Debug.Log("!CardName : " + makeCards.sellPrice.ToString());
                buyCardBase.SetBoughtCard(makeCards);
                Label_Tip.Text = GameContext.GetInstance.localizedStringData.GetString(1013);
                GameContext.GetInstance.uiSoundPlayer.EffectSoundPlay(EffectSoundPlayer.eCARD_SOUND.Shop_001);
                CardSystemManager.GetInstance.AddCardOnInventory(makeCards);
                SetVisible_MainThreeBtns(false);
                CardSystemManager.GetInstance.SaveShop();
                gc.gameData.SaveSpecialUpgradeInfo();
            }
        }
        else  //크리스탈 부족..
        {
            SetAutoDeleteTextInfo(SHOPINFOTXT, 1026, 2.5f);
            Panel_MarketPopup[0].Hide();
            fn_CallPopup();
            GameContext.GetInstance.uiSoundPlayer.EffectSoundPlay(EffectSoundPlayer.UI_SOUND.CANCEL);
        }
    }

