    public GameObject Panel_MarketResult;
    public GameObject Panel_CompResult;
    public void OnCardGetClicked(dfControl control, dfMouseEventArgs mouseEvent) // '카드상점' : '부스터카드 클릭' : '구매팝업' : '예' : '카드뒷면클릭' : '획득' 클릭 시 진입
    {
        if (Panel_Pupup.IsVisible)
            return;

        GameContext.GetInstance.uiSoundPlayer.EffectSoundPlay(EffectSoundPlayer.UI_SOUND.OK);
        //구매 or compound 한 카드 인벤토리로...       
        Clip_FrontfaceCard.CARDBASESTATE state = cardResultViewer.cardBaseState;
        if (state == Clip_FrontfaceCard.CARDBASESTATE.CARD_BUYRESULT_VIEW)
        {
            if (cardResultViewer.ClickedGetButton() == true)
            {
                CardSystemManager.GetInstance.SortInventory(CardSortOption.SORT_LEVEL_DESCEND);
                //SetMaskToBase(EMPTY_SHOPBASECLIP);  //남은카드가 없다.

                Label_Tip.Text = GameContext.GetInstance.localizedStringData.GetString(SHOPINFOTXT);

                SetVisible_MainThreeBtns(true);

                fn_ActiveMenu(Panel_MarketMenu, "ScrollPanel_Market");

                enableMenuChange = true;
                fn_SideMenuEnable(enableMenuChange);

                CardSystemManager.GetInstance.SortInventory(CardSortOption.SORT_LEVEL_DESCEND);
                isInvenModified = true;
                CardSave();
            }
            else
                SetAutoDeleteTextInfo(DECISIONMSG, LACKINVEN, 2.5f);
        }
        else if (state == Clip_FrontfaceCard.CARDBASESTATE.CARD_COMPRESULT_VIEW)
        {
            GameContext.GetInstance.gameData.onPauseProcessing = true;
            if (cardResultViewer.ClickedGetButton() == true)  //순서바꾸면 안됨...
            {
                invenCard_CompBase.ClearClipCard();

                CardBase[] cards = CardSystemManager.GetInstance.GetCardsFromInventory();
                if (cards.Length > 0)
                    invenCard_CompBase.SetInvenCards(cards, Clip_FrontfaceCard.CARDBASESTATE.COMP_BASE_VIEW);

                cardCompViewer.DisplayPrevBaseClip();
                Label_Tip.Text = GameContext.GetInstance.localizedStringData.GetString(1015);
                enableMenuChange = true;
                fn_SideMenuEnable(enableMenuChange);

                SetVisible_MainThreeBtns(true);

                //cardShopBase.dragable = true;
                isInvenModified = true;
                CardSystemManager.GetInstance.SortInventory(CardSortOption.SORT_LEVEL_DESCEND);
                CardSave();
            }
            else
                SetAutoDeleteTextInfo(DECISIONMSG, LACKINVEN, 2.5f);
        }
    }

