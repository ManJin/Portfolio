    Vector3 GetCharMoveDir()
    {
        //카메라 보고 있는 방향 기준으로 변경할것.
        Vector3 pos = Vector3.zero;
        screenSpace = Quaternion.Euler(0, Camera.main.transform.eulerAngles.y, 0);
        screenForward = screenSpace * Vector3.forward;
        screenRight = screenSpace * Vector3.right;
        InputManager input = GameContext.GetInstance.inputManager;
#if UNITY_EDITOR || UNITY_STANDALONE
        pos = input.GetAxis(InputManager.InputAxis.X360_LeftStick_X) * screenRight + input.GetAxis(InputManager.InputAxis.X360_LeftStick_X) * screenForward;
#elif UNITY_ANDROID
        pos = input.NormalizedTouchPos.x * screenRight + input.NormalizedTouchPos.y * screenForward;
#endif

        return new Vector3(pos.x, 0, pos.z).normalized;
    }

    void InputHero()
    {
        InputManager input = GameContext.GetInstance.inputManager;

        if (input.GetCrossInput(InputManager.Direction.LEFT) || input.GetCrossInput(InputManager.Direction.RIGHT))
            MoveState = true;

        else if (input.GetCrossInput(InputManager.Direction.UP) || input.GetCrossInput(InputManager.Direction.DOWN))
            MoveState = true;

        else
            MoveState = false;

        if (input.GetButtonDown(InputManager.InputButton.X360_RB))
            myBattleStat.movSpeed = myBattleStat.movSpeed * 3.0f;

        if (input.GetButtonUp(InputManager.InputButton.X360_RB))
            myBattleStat.movSpeed = myBattleStat.movSpeed / 3.0f;
    }

