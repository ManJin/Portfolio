    public void ClickSkill()
    {
        if (myBattleStat.soulGuage >= 100)
        {
            GameObject skillBullet = ObjectPoolManager.Instance.Spawn("DummySkill", LeftHandTr.position);
            ParticleSystem ps = skillBullet.transform.GetChild(0).particleSystem;
            if (myBattleStat.soulGuage == 500)
            {
                ps.startSize = 6;
                ps.startColor = Color.red;
                UseSoulGuage(500);
            }
            else if (myBattleStat.soulGuage >= 400 && myBattleStat.soulGuage < 500)
            {
                ps.startSize = 5;
                ps.startColor = Color.yellow;
                UseSoulGuage(400);
            }
            else if (myBattleStat.soulGuage >= 300 && myBattleStat.soulGuage < 400)
            {
                ps.startSize = 4;
                ps.startColor = Color.green;
                UseSoulGuage(300);
            }
            else if (myBattleStat.soulGuage >= 200 && myBattleStat.soulGuage < 300)
            {
                ps.startSize = 3;
                ps.startColor = Color.blue;
                UseSoulGuage(200);
            }
            else if (myBattleStat.soulGuage >= 100 && myBattleStat.soulGuage < 200)
            {
                ps.startSize = 2;
                UseSoulGuage(100);
            }
            InGameCircleGuage guage = GameObject.Find("SkillCircleOn").GetComponent<InGameCircleGuage>();
            guage.InitCurrentArray();
        }
    }
    
