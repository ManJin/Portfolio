public class HeroSetting
{
    public readonly string filePath = "/Data/";
    public readonly string fileName = "HeroStatus";
    public readonly string expend = ".txt";
    public string content;
    public CharacterBase.Stat stat;
    public CharacterBase.BattleStat bstat;

    public HeroSetting()
    {
        stat = new CharacterBase.Stat();
        bstat = new CharacterBase.BattleStat();
        if (LoadStatus(fileName))
        {
            Debug.Log("Hero Status Loaded");
        }
        else
        {
            Debug.Log("Hero Status Load Failed");
        }
    }

    public bool LoadStatus(string filename)
    {
        CSVLoader loader = new CSVLoader(filename);
        if (loader != null)
        {
            content = "";
            for (int i = 0; i <= loader.LineMaxNum; i++)
            {
                if (i != 0)
                {
                    content += loader.GetString();
                    content += "\n";
                }
                loader.NextLine();
            }
            
            string[] loadedValue = content.Split(" "[0]);
            stat.level = int.Parse(loadedValue[0]);
            stat.power = float.Parse(loadedValue[1]);
            stat.technique = float.Parse(loadedValue[2]);
            stat.mental = float.Parse(loadedValue[3]);
            stat.vital = float.Parse(loadedValue[4]);

            bstat.lifeGuage = float.Parse(loadedValue[5]);
            bstat.attack = float.Parse(loadedValue[6]);
            bstat.movSpeed = float.Parse(loadedValue[9]);
            bstat.activityGuage = float.Parse(loadedValue[7]);
            bstat.dashSpeed = bstat.movSpeed * 2.0f;
            bstat.soulGuage = 500;
            bstat.atkSpeed = float.Parse(loadedValue[8]);

            return true;
        }
        else
            return false;

    }
}
