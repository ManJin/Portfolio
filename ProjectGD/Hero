    public bool GetDamage(float amount)
    {
        if (!unbeatableState)
        {
            //Debug.Log("DebugLife : " + (myBattleStat.lifeGuage - amount));
            if (myBattleStat.lifeGuage - amount > 0.0f)
            {
                myBattleStat.lifeGuage -= amount;
                SetCharState(CharacterBase.State.DAMAGE);
                HeroFsm.SendEvent("DOWN");
                unbeatableState = true;
                return true;
            }
            else
            {
                myBattleStat.lifeGuage = 0.0f;
                SetCharState(CharacterBase.State.DEAD);
                HeroFsm.SendEvent("DIE");
                unbeatableState = true;
                return false;
            }
        }
        return false;
    }

