    void PickAttackTarget()
    {
        if (Input.GetMouseButtonUp(0))
        {
            Ray ray = Camera.main.ScreenPointToRay(Input.mousePosition);
            int layerMaskUnit = 1 << LayerMask.NameToLayer("DamageArea");
            RaycastHit[] hits;
            hits = Physics.RaycastAll(ray, Mathf.Infinity, layerMaskUnit);

            int i = 0;
            while (i < hits.Length)
            {
                CurrentTargetGolem = hits[i].transform.root.GetComponent<Golem>();
                if (CurrentTargetGolem.HitTargetUI[hits[i].transform.name].IsTargetActive)
                {
                    if (!CurrentTargetGolem.HitLocationTr.Contains(hits[i].transform))
                    {
                        CurrentTargetGolem.HitTargetUI[hits[i].transform.name].SetActiveColor();
                        CurrentTargetGolem.HitLocationTr.Add(hits[i].transform);
                        AttackTargetOn = true;
                    }
                    return;
                }
                i++;
            }
        }
    }

    void UnbeatableCheck()
    {
        if (unbeatableState == true && myState != State.DEAD)
        {
            if (myState != State.EVADE)
            {
                unbeatableTime += Time.deltaTime;
                HeroFlickerTime += Time.deltaTime;
            }

            if (unbeatableTime > 1.3f && HeroFlickerTime > 0.1f)
            {
                foreach (SkinnedMeshRenderer mr in HeroMeshs)
                {
                    mr.enabled = !mr.enabled;
                }
                HeroFlickerTime = 0.0f;
            }

            if (unbeatableTime > 2.5f)
            {
                unbeatableState = false;
                unbeatableTime = 0.0f;
                HeroFlickerTime = 0.0f;

                foreach (SkinnedMeshRenderer mr in HeroMeshs)
                {
                    mr.enabled = true;
                }
            }
        }
    }
    
    void ChargeActivityGuage()
    {
        if (myState == State.IDLE || myState == State.MOVE || myState == State.HIDE || myState == State.HIDEMOVE || myState == State.ATTACK)
        {
            if (myBattleStat.activityGuage < maximumActivityGuage)
            {
                myBattleStat.activityGuage += chargeActivityAmount;
            }
            else
            {
                myBattleStat.activityGuage = maximumActivityGuage;
            }
        }
    }

    void CalSoulGuageCount()
