            return false;
        }
    }

    public bool LockEnemyWithoutInput()
    {
        //Debug.Log("Without Input");
        Golem[] golems = GameObject.FindObjectsOfType<Golem>();

        float minDist = 999999999999.0f;
        int enemyNumber = -1;
        if (golems.Length == 0)
        {
            CurrentTargetGolem = null;
            return false;
        }

        float radAngle = Camera.main.fieldOfView * Mathf.Deg2Rad;
        float radHFOV = 2 * Mathf.Atan(Mathf.Tan(radAngle / 2) * Camera.main.aspect);
        float hfov = radHFOV * Mathf.Rad2Deg;

        if (CurrentTargetGolem == null)
        {//기존타겟이 없으면 
            for (int i = 0; i < golems.Length; i++)
            {

                Vector3 enemyPos = golems[i].GetTransform().position;
                Vector3 cameraPos = myTrans.position;
                Vector3 cameraFor = myTrans.forward;
                Vector3 dixy = (enemyPos - cameraPos).normalized;

                float theta = Mathf.Acos(Vector3.Dot(cameraFor, dixy)) * Mathf.Rad2Deg;
                if (golems[i].GetState() == EnemyBase.State.DEATH) continue;// 찾은 골렘이 죽어있으면 제외

                if (Mathf.Abs(theta) > (hfov / 2)) continue;// 전방 일정 범위 밖이면 제외

                float dist = Mathf.Sqrt(Mathf.Pow((enemyPos.x - myTrans.position.x), 2) + Mathf.Pow((enemyPos.z - myTrans.position.z), 2));

                if (dist > range.radius) continue;// 캐릭터와의 거리가 공격 사거리 밖이면 제외

                if (minDist >= dist)
                {
                    minDist = dist;
                    enemyNumber = i;
                }
            }
            if (enemyNumber != -1)
            {
                if (golems[enemyNumber].GetState() == EnemyBase.State.DEATH)
                {
                    CurrentTargetGolem = null;
                    return false;
                }
                CurrentTargetGolem = golems[enemyNumber];
                return true;
            }
            else// 1번 범위와 2번 범위의 교집합 되는 공간에서의 검색에서 없으면
            {
                if (LockEnemyInSecondRange())
                    return true;
                CurrentTargetGolem = null;
                return false;
            }
        }
        else//현재 타겟이 있으면 그냥 그 타겟 유지.
        {
            return true;
        }
        
    }
    public bool ViewCheck()
    {
        if (CurrentTargetGolem == null) return false;

        Vector3 enemyPos = CurrentTargetGolem.transform.position;
        Vector3 cameraPos = myTrans.position;
        Vector3 cameraFor = GetCharMoveDir();
        Vector3 dixy = (enemyPos - cameraPos).normalized;

        float theta = Mathf.Acos(Vector3.Dot(cameraFor, dixy)) * Mathf.Rad2Deg;
        if (Mathf.Abs(theta) > 45.0f)
        {
            myTrans.rotation = Quaternion.LookRotation(GetCharMoveDir());
            return true;
        }

        return false;
    }

