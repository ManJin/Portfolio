    public static float Angle(Vector3 v0, Vector3 v1, Vector3 up)
    {
        return Vector3.Angle(v0, v1) * (Vector3.Dot(up, Vector3.Cross(v0, v1)) > 0.0f ? 1.0f : -1.0f);
    }
    public bool FindEnemyLeft()
    {
        StageAssetManager sm = StageAssetManager.GetInstance;
        Vector3 forward = new Vector3(myTrans.forward.x, 0, myTrans.forward.z);
        Vector3 direction = new Vector3(sm.HeroClass.GetTransform().position.x, 0, sm.HeroClass.GetTransform().position.z) - new Vector3(myTrans.position.x, 0, myTrans.position.z);

        Vector3 crossValue = Vector3.Cross(forward, direction);

        if (crossValue.y > 0)
            return true;
        else
            return false;
    }
    public TargetRange GetTargetRange()
    {
        Vector3 heroLocation = hero.GetTransform().position;
        Vector3 dir = (heroLocation - myTrans.position).normalized;

        charDeg = Vector3.Angle(myTrans.forward, dir);
        //charRad = Mathf.Atan2(heroLocation.x, heroLocation.z);
        charRad = charDeg * Mathf.Deg2Rad;
        charRad = Mathf.Abs(charRad);

        if (charRad >= 0.0f && charRad < _1stRadian)
        {
            return range = TargetRange.FIRST;
        }
        else if (charRad >= _1stRadian && charRad < _2ndRadian)
        {
            return range = TargetRange.SECOND;
        }
        else
        {
            return range = TargetRange.THIRD;
        }
    }

    public void SetGolemHitTarget()
    {
