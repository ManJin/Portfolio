public class GolemSetting
{
    public readonly string filePath = "EnemyData/";
    public readonly string expend = ".csv";
    public string content;

    public ObjectFactory.EnemyType EnemyType = ObjectFactory.EnemyType.Temple;

    public SortedDictionary<string, string> animationDic = new SortedDictionary<string,string>();
    public SortedDictionary<string, string[]> patternDic = new SortedDictionary<string, string[]>();
    public SortedDictionary<string, string[]> aiDic = new SortedDictionary<string, string[]>();
    public SortedDictionary<string, float> statusDic = new SortedDictionary<string, float>();

    public GolemSetting()
    {
        if (LoadAniList())
            Debug.Log("Golem Animation List Loaded");
        else
            Debug.Log("Golem Animation List Failed");
    }

    public void GolemAiInit(uint golemid)
    {
        EnemyType = (ObjectFactory.EnemyType)golemid;

        if (LoadPattern())
            Debug.Log(EnemyType.ToString() + " : Pattern Loaded");
        else
            Debug.Log(EnemyType.ToString() + " : Pattern Load Failed");

        if (LoadAI())
            Debug.Log(EnemyType.ToString() + " : AI Loaded");
        else
            Debug.Log(EnemyType.ToString() + " : AI Load Failed");

        if (LoadStatus())
            Debug.Log(EnemyType.ToString() + " : Status Loaded");
        else
            Debug.Log(EnemyType.ToString() + " : Status Load Failed");
    }
    public bool LoadAniList()
    {
        CSVLoader loader = new CSVLoader("AnimationList" + expend);
        if (loader != null)
        {
            string tempVal = "";
            loader.NextLine();

            for (int i = 1; i < loader.LineMaxNum; i++)
            {
                string tempKey = loader.GetString();
                
                if (!animationDic.TryGetValue(tempKey, out tempVal))
                {
                    tempVal = loader.GetString();
                    animationDic.Add(tempKey, tempVal);
                }
                loader.NextLine();
            }
            return true;
        }
        else
            return false;
    }

    public bool LoadAI()
    {
        CSVLoader loader = new CSVLoader(filePath + EnemyType.ToString() + "/AI" + expend);
        if (loader != null)
        {
            string[] tempVal;
            loader.NextLine();
            for (int i = 1; i < loader.LineMaxNum; i++)
            {
                string tempKey = loader.GetString();
                if (!aiDic.TryGetValue(tempKey, out tempVal))
                {
                    tempVal = new string[loader.GetLineColumnCount() - 1];

                    for (int j = 0; j < loader.GetLineColumnCount() - 1; j++)
                    {
                        tempVal[j] = loader.GetString();
                    }
                    aiDic.Add(tempKey, tempVal);
                }
                loader.NextLine();
            }
            return true;
        }
        else
            return false;
    }

    public bool LoadPattern()
    {
        CSVLoader loader = new CSVLoader(filePath + EnemyType.ToString() + "/Pattern" + expend);
        string tempkey ="";
        string[] tempVal;
        if (loader != null)
        {
            loader.NextLine();
            for(int i = 1 ; i < loader.LineMaxNum; i++)
            {
                tempkey = loader.GetString();
                if(!patternDic.TryGetValue(tempkey, out tempVal))
                {
                    tempVal = new string[loader.GetLineColumnCount() - 1];

                    for (int j = 0; j < loader.GetLineColumnCount() - 1; j++)
                    {
                        tempVal[j] = loader.GetString();
                    }
                    patternDic.Add(tempkey, tempVal);
                }
                
                loader.NextLine();
            }
            return true;
        }
        else
            return false;
    }

    public bool LoadStatus()
    {
        CSVLoader loader = new CSVLoader(filePath + EnemyType.ToString() + "/Status" + expend);
        if (loader != null)
        {
            string tempKey = "";
            float tempVal = 0;
            loader.NextLine();

            for (int i = 1; i < loader.LineMaxNum; i++)
            {
                tempKey = loader.GetString();

                if (!statusDic.TryGetValue(tempKey, out tempVal))
                {
                    tempVal = loader.GetFloat();
                    statusDic.Add(tempKey, tempVal);
                }
                loader.NextLine();
            }

            return true;
        }
        else
            return false;
    }
}