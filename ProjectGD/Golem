    void DegreeToRadian()
    {
        _1stRadian =  myBattleStat._1stRange * Mathf.Deg2Rad;
        _2ndRadian = myBattleStat._2ndRange * Mathf.Deg2Rad;
    }

    float charDeg = 0.0f;

    void SetGolemDamageAreaUI()
    {
        StageAssetManager sm = StageAssetManager.GetInstance;
        int index = 1;
        foreach (BoxCollider col in GolemHitCollider)
        {
            GameObject LockOnTargetObj = NGUITools.AddChild(sm.IngameStatui.gameObject, Resources.Load("Prefabs/RockOn") as GameObject);
            LockOnTargetObj.name = "LockOn" + (index++).ToString("00");
            InGameLockOn lockon = LockOnTargetObj.GetComponent<InGameLockOn>();
            lockon.RegisterTarget(col.transform, this);
            HitTargetUI.Add(col.transform.name, lockon);
        }
    }

    void SettingGolem()
    {
        float tempVal = 0.0f;
        if(Setting.statusDic.TryGetValue("Level", out tempVal))
            int.TryParse(tempVal.ToString(), out myStat.level);
        Setting.statusDic.TryGetValue("Power", out myStat.power);
        Setting.statusDic.TryGetValue("Technique", out myStat.technique);
        Setting.statusDic.TryGetValue("Mental", out myStat.mental);
        Setting.statusDic.TryGetValue("Vital", out myStat.vital);
        Setting.statusDic.TryGetValue("Life", out myBattleStat.lifeGuage);
        Setting.statusDic.TryGetValue("Attack", out myBattleStat.attack);
        Setting.statusDic.TryGetValue("MoveSpeed", out myBattleStat.movSpeed);
        Setting.statusDic.TryGetValue("1stRange", out myBattleStat._1stRange);
        Setting.statusDic.TryGetValue("2ndRange", out myBattleStat._2ndRange);
        animationDic = Setting.animationDic;
        patternDic = Setting.patternDic;
        aiDic = Setting.aiDic;
        statusDic = Setting.statusDic;
    }

