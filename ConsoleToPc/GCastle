    /// <summary>
    /// CalculatePlayerGCastleBaseStatus() 기본 스텟 계산
    /// </summary>
    /// <param name="type"></param>
    /// <returns></returns>
    protected long CalculatePlayerGCastleBaseStatus(GCastle.Status type)
    {
        long retVal = 0;
        //끝
        long baseVal = GetGCastleBaseStatus(1,type);
        //끝
        long shampuruVal = gameData.ShampuruData.GetShampuruRevisionValue(type);

        retVal = baseVal + shampuruVal;
        if (retVal < (int)CalculateValue.GCASTLE_STATUS_MIN)
            retVal = (int)CalculateValue.GCASTLE_STATUS_MIN;
        return retVal;
    }
    /// <summary>
    /// CalculateEnemyGCastleBaseStatus() 기본 스텟 계산
    /// </summary>
    /// <param name="type"></param>
    /// <returns></returns>
    protected long CalculateEnemyGCastleBaseStatus(GCastle.Status type)
    {
        long retVal = 0;
        //적함선 레벨 가져올수있도록.
        int playerLevel = gameData.SaveDataManager.SaveData.PlayerInfo.GetPlayer(1).CurrLevel;
        int rand = 0;
        long base_param = GetGCastleBaseStatus(gameData.EnemyGCastleID, type);
        
        long revision_param = GetGCastleRevisionStatus(gameData.EnemyGCastleID, type);

        double adjust = 0;

        while (playerLevel > 1)
        {
            rand = Random.Range(90, 100);
            adjust += ((revision_param / 100.0f) * (rand / 100.0f));
            playerLevel--;
            if (playerLevel <= 1)
                break;
        }

        retVal = (long)(base_param * adjust);

        if (retVal < (int)CalculateValue.GCASTLE_STATUS_MIN)
            retVal = (int)CalculateValue.GCASTLE_STATUS_MIN;

        return retVal;
    }

