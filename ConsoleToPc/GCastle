    /// <summary>
    /// CalculatePlayerGCastleBattleStatus() 플레이어 스킬에 적용되는 앖. 
    /// </summary>
    /// <param name="type"></param>
    /// <param name="skillID"></param>
    /// <returns></returns>
    public long CalculatePlayerGCastleBattleStatus(GCastle.Status type, int skillID)
    {
        long retVal = 0;
        //step4
        long baseVal = GetStatus(type);// +gameData.ShampuruData.GetShampuruRevisionValue(type);
        //if(type == Status.ATK)
            
        long revisionVal = gameData.GCastleData.SkillData.GetGCastleSkillData(skillID).EffectParam;
        if (revisionVal > 100)
            revisionVal = 100;

        retVal = baseVal * (100 + revisionVal) / 100;

        return retVal;
    }
