    /// </summary>
    /// <param name="type"></param>
    /// <param name="id"></param>
    /// <param name="spec"></param>
    /// <returns></returns>
    int GetTalkSearchIndex(GCastleTalk.TalkSubType type, int id, int spec = 999)
    {
        int[] index_can = new int[8];
        int index_max = 0;
        int index_ran = 0;// 번호 후보 랜덤값

        int voice_max = gameData.GCastleData.VoiceData.GetMaximumDataCount();
        IEnumerable<GCastleVoiceData> voiceData = gameData.GCastleData.VoiceData.GetIEnumerableData(type, id);

        foreach(GCastleVoiceData data in voiceData)
        {
            index_can[index_max] = data.ID;
            index_max++;
            if (index_max >= 8)
                break;
        }
        if (index_max <= 0)
            return -1;
        if (index_max == 1)
            return index_can[0];
        if (spec < index_max)
            return index_can[spec];

        index_ran = Random.Range(0, index_max - 1);

        return index_can[index_ran];
    }
