    /// <summary>
    /// CalculateEnhenceStatus(GCastleEnhence.Type type) 강화 타입별 호출되면 강화된 값(기본값 제외한) 을 밷음.
    /// </summary>
    /// <param name="type"></param>
    /// <returns></returns>
    protected int CalculateEnhenceStatus(GCastleEnhence.Type type)
    {
        GCastleEnhence retVal = null;

        int power = 0;
        int id = 0;
        switch (type)
        {
            case GCastleEnhence.Type.ATK:
            case GCastleEnhence.Type.DEF:
                id = 31;
                break;
            case GCastleEnhence.Type.INT:
            case GCastleEnhence.Type.MND:
                id = 32;
                break;
            case GCastleEnhence.Type.AGI:
            case GCastleEnhence.Type.TEC:
                id = 33;
                break;
            case GCastleEnhence.Type.ALL:
                id = 34;
                break;
            case GCastleEnhence.Type.ALLPLUS:
                id = 35;
                break;
        }
        power = gameData.GCastleData.SkillData.GetGCastleSkillData(id).EffectParam;

        if (m_dicEnhence.TryGetValue(type, out retVal))
        {
            if (retVal.Flag == false)
                retVal.Flag = true;

            retVal.Turn = (int)CalculateValue.ENHENCE_TURN_MAX;
            retVal.Value += power;

            return retVal.Value;
        }
        return 0;
    }
    /// <summary>
    /// CheckEnhenceTrun() 매 턴 체크하여 현재 강화상태가 어떠한지에 대한 체크를 함. 
    /// </summary>
    protected void CheckEnhenceTrun()
    {
        for (GCastleEnhence.Type type = GCastleEnhence.Type.ATK; type < GCastleEnhence.Type.ALLPLUS; type++)
        {
            EnhenceTurnStatus(type);
        }
    }
    void EnhenceTurnStatus(GCastleEnhence.Type type)
    {
        GCastleEnhence retVal = null;
        if (m_dicEnhence.TryGetValue(type, out retVal))
        {
            if (retVal.Flag == true)
            {
                retVal.Turn--;

                if (retVal.Turn <= 0)
                {
                    retVal.Turn = 0;
                    retVal.Value = 0;
                    retVal.Flag = false;
                }
            }
        }
    }

    /// <summary>
    /// CheckEnhenceMax() True 일 경우 최대 강화가 되어 강화 루틴을 타지 않음
    /// </summary>
    /// <returns></returns>
    protected bool CheckEnhenceMax()
    {
        bool retVal = false;
        GCastleEnhence outVal = null;
        if(m_dicEnhence.TryGetValue(GCastleEnhence.Type.ALL, out outVal))
        {
            if(outVal.Flag == true)
                retVal = true;
        }
        if (m_dicEnhence.TryGetValue(GCastleEnhence.Type.ALLPLUS, out outVal))
        {
            if (outVal.Flag == true)
                retVal = true;
        }
        return retVal;
    }


    /// <summary>
    /// CalculatePlayerGCastleHP() 플레이어 함선 HP 반환
    /// </summary>
    /// <returns></returns>
    protected long CalculatePlayerGCastleHP()
    {
        long retVal = 0;
        long baseVal = GetGCastleBaseStatus(1, Status.HP);
        long totalATK = CalculatePlayerGCastleBaseStatus(Status.ATK);
        long totalDEF = CalculatePlayerGCastleBaseStatus(Status.DEF);
        long totalAGI = CalculatePlayerGCastleBaseStatus(Status.AGI);

        retVal = baseVal + ((totalATK + totalDEF + totalAGI ) / 3 * 10);

        if (retVal > (int)CalculateValue.GCASTLE_HP_MAX)
            retVal = (int)CalculateValue.GCASTLE_HP_MAX;
        if(retVal < (int)CalculateValue.GCASTLE_HP_MIN)
            retVal = (int)CalculateValue.GCASTLE_HP_MIN;

        return retVal;
    }
    /// <summary>
    /// CalculateEnemyGCastleHP() 적 함선 HP 반환
    /// </summary>
    /// <returns></returns>
    protected long CalculateEnemyGCastleHP()
    {
        long retVal = 0;
        long baseVal = GetGCastleBaseStatus(gameData.EnemyGCastleID, Status.HP);
        long revisionVal = GetGCastleRevisionStatus(gameData.EnemyGCastleID, Status.HP);
        float adjust = 1.0f;
        int level = gameData.SaveDataManager.SaveData.PlayerInfo.GetPlayer(1).CurrLevel;
        while (level > 1)
        {
            adjust += (revisionVal / 100.0f * Random.Range(90.0f, 110.0f) / 100.0f);
            level--;
            if (level <= 1)
                break;
        }
        retVal = (long)(baseVal * adjust);

        
        if (retVal < (int)CalculateValue.GCASTLE_HP_MIN)
            retVal = (int)CalculateValue.GCASTLE_HP_MIN;

        return retVal;
    }

    /// <summary>
    /// HP 회복 계산식 
    /// HP 회복? 포인트 = 최대 HP * 보정 값 / 100 + {(INT + MND) / 2 / 10} + 공격력 
    /// HP 회복? 포인트 = 최대 HP * 보정 값 / 100 + {(INT + MND) / 2} + 공격력 11/11 수정 
    /// </summary>
    /// <param name="castleID"></param>
    /// <param name="skill"></param>
    /// <returns></returns>
    protected long CalculateGCastleRecoverHP(int castleID , GCastleSkillData skill)
    {
        long retVal = 0;
        if (skill.SubType != eGCastleSkillSubType.HealHP)
            return 0;

        
        long maxHP = GetStatus(Status.HP);

        long revisionVal = skill.EffectParam;

        retVal = maxHP * revisionVal / 100;

        long battleINT = 0;
        long battleMND = 0;

        if (castleID == 1)
        {
            battleINT = CalculatePlayerGCastleBattleStatus(Status.INT, skill.ID);
            battleMND = CalculatePlayerGCastleBattleStatus(Status.INT, skill.ID);
        }
        else
        {
            battleINT = CalculateEnemyGCastleBattleStatus(Status.INT, skill.ID);
            battleMND = CalculateEnemyGCastleBattleStatus(Status.INT, skill.ID);
        }

        retVal += (battleINT + battleMND) / 2;

        long atkPower = skill.AttackPower;
        
        retVal += atkPower;

        return retVal;
    }
    public long GetAmountRecoverHP()
    {
        if (scriptOwner == eAttacker.Player)
        {
            return CalculateGCastleRecoverHP(1, m_Skill);
        }
        else
        {
            return CalculateGCastleRecoverHP(gameData.EnemyGCastleID, m_Skill);
        }
    }
