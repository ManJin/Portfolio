    public void SetEnhenceStatus(int skillID)
    {
        switch (skillID)
        {
            case 31:
                CalculateEnhenceStatus(GCastleEnhence.Type.ATK);
                CalculateEnhenceStatus(GCastleEnhence.Type.DEF);
                break;
            case 32:
                CalculateEnhenceStatus(GCastleEnhence.Type.INT);
                CalculateEnhenceStatus(GCastleEnhence.Type.MND);
                break;
            case 33:
                CalculateEnhenceStatus(GCastleEnhence.Type.AGI);
                CalculateEnhenceStatus(GCastleEnhence.Type.TEC);
                break;
            case 34:
                CalculateEnhenceStatus(GCastleEnhence.Type.ATK);
                CalculateEnhenceStatus(GCastleEnhence.Type.DEF);
                CalculateEnhenceStatus(GCastleEnhence.Type.INT);
                CalculateEnhenceStatus(GCastleEnhence.Type.MND);
                CalculateEnhenceStatus(GCastleEnhence.Type.AGI);
                CalculateEnhenceStatus(GCastleEnhence.Type.TEC);
                break;
            case 35:
                for (int i = 0; i < 2; i++)
                {
                    CalculateEnhenceStatus(GCastleEnhence.Type.ATK);
                    CalculateEnhenceStatus(GCastleEnhence.Type.DEF);
                    CalculateEnhenceStatus(GCastleEnhence.Type.INT);
                    CalculateEnhenceStatus(GCastleEnhence.Type.MND);
                    CalculateEnhenceStatus(GCastleEnhence.Type.AGI);
                    CalculateEnhenceStatus(GCastleEnhence.Type.TEC);
                }
                break;
        }
    }

