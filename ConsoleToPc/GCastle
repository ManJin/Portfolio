    public int GetCategoryCount(eGCastleSkillType type)
    {
        int retVal = 0;
        IEnumerable<GCastleSkillData> list = gameData.GCastleData.SkillData.GetSkillsListInCategory(type);
        bool[] flags = { false, false, false, false, false, false, false };
        int tempVal = 0;
        int trueVal = 0;
        foreach (GCastleSkillData data in list)
        {
            if (data.GetLearnShampuru(eShampuruType.Normal) != 0) flags[0] = true;
            if (data.GetLearnShampuru(eShampuruType.Attack) != 0) flags[1] = true;
            if (data.GetLearnShampuru(eShampuruType.Guard) != 0) flags[2] = true;
            if (data.GetLearnShampuru(eShampuruType.Magic) != 0) flags[3] = true;
            if (data.GetLearnShampuru(eShampuruType.Support) != 0) flags[4] = true;
            if (data.GetLearnShampuru(eShampuruType.Far) != 0) flags[5] = true;
            if (data.GetLearnShampuru(eShampuruType.Special) != 0) flags[6] = true;

            foreach (bool flag in flags)
                if (flag)
                    trueVal++;

            if (flags[0] == true)
            {
                //Debug.Log("Normal " + gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Normal) + " : " + data.GetLearnShampuru(eShampuruType.Normal));
                if (gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Normal) >= data.GetLearnShampuru(eShampuruType.Normal))
                    tempVal++;
            }
            if (flags[1] == true)
            {
                //Debug.Log("Attack " + gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Attack) + " : " + data.GetLearnShampuru(eShampuruType.Attack));
                if (gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Attack) >= data.GetLearnShampuru(eShampuruType.Attack))
                    tempVal++;
            }
            if (flags[2] == true)
            {
                //Debug.Log("Guard " + gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Guard) + " : " + data.GetLearnShampuru(eShampuruType.Guard));
                if (gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Guard) >= data.GetLearnShampuru(eShampuruType.Guard))
                    tempVal++;
            }
            if (flags[3] == true)
            {
                //Debug.Log("Magic " + gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Magic) + " : " + data.GetLearnShampuru(eShampuruType.Magic));
                if (gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Magic) >= data.GetLearnShampuru(eShampuruType.Magic))
                    tempVal++;
            }
            if (flags[4] == true)
            {
                //Debug.Log("Support " + gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Support) + " : " + data.GetLearnShampuru(eShampuruType.Support));
                if (gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Support) >= data.GetLearnShampuru(eShampuruType.Support))
                    tempVal++;
            }
            if (flags[5] == true)
            {
                //Debug.Log("Far " + gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Far) + " : " + data.GetLearnShampuru(eShampuruType.Far));
                if (gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Far) >= data.GetLearnShampuru(eShampuruType.Far))
                    retVal++;
            }
            if (flags[6] == true)
            {
                //Debug.Log("Special " + gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Special) + " : " + data.GetLearnShampuru(eShampuruType.Special));
                if (gameData.ShampuruData.GetShampuruCountByCategory(eShampuruType.Special) >= data.GetLearnShampuru(eShampuruType.Special))
                    tempVal++;
            }

            if (tempVal >= trueVal)
            {
                OpenSkillIDs[retVal] = data.ID;
                retVal++;
            }
            tempVal = 0;
            trueVal = 0;
            for (int i = 0; i < 7; i++)
                flags[i] = false;
        }
        return retVal;
    }
