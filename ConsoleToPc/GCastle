    /// <summary>
    /// 스킬에 의한 상승 보정치를 더해서 반환해준다. 
    /// </summary>
    /// <param name="type"></param>
    /// <returns></returns>
    public long GetStatus(GCastle.Status type)
    {
        long retVal = -1;
        double temp = 0.0f;

        switch (type)
        {
            case Status.ATK:
                temp = ATK * 0.01f * (100 * GetEnhenceValue(GCastleEnhence.Type.ATK));
                break;
            case Status.DEF:
                temp = DEF * 0.01f * (100 * GetEnhenceValue(GCastleEnhence.Type.DEF));
                break;
            case Status.INT:
                temp = INT * 0.01f * (100 * GetEnhenceValue(GCastleEnhence.Type.INT));
                break;
            case Status.MND:
                temp = MND * 0.01f * (100 * GetEnhenceValue(GCastleEnhence.Type.MND));
                break;
            case Status.AGI:
                temp = AGI * 0.01f * (100 * GetEnhenceValue(GCastleEnhence.Type.AGI));
                break;
            case Status.TEC:
                temp = TEC * 0.01f * (100 * GetEnhenceValue(GCastleEnhence.Type.TEC));
                break;
            case Status.HP:
                return maxHP;
            case Status.SP:
                return maxSP;
        }
        if (temp < 1.0f)
            temp = 1.0f;
        retVal = (long)temp;
        return retVal;
    }
