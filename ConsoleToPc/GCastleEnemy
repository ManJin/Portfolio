    /// <summary>
    /// AITableSet() 현재 HP 상황에 따라 동작종류 설정
    /// 설탕? 1 
    ///어떤 생각 전투하거나 판정 
    ///
    ///G 캐슬의 HP 판정 
    ///HP가 100 ~ 61 % 생각 테? 블루 1 
    ///HP가 60 ~ 31 % 생각 테? 블루 2 
    ///HP가 30 % 이하 사고 테? 블루 3 
    ///
    ///※ 회복 스킬로 HP가 회복해도 생각 테이블 변경되지 않음. 
    ///
    ///@param GC_PLAYER * pPlay [in] 플레이어 ?? 造体 
    ///
    ///@return 생각 테? 불? 造体 
    /// </summary>
    void AITableSet()
    {
        if (currentHP <= lowestHP)
        {
            lowestHP = currentHP;
        }
        if (lowestHP <= maxHP * (30.0f / 100.0f))
        {
            aiTable = eAIType.Danger;
        }
        else if (lowestHP <= maxHP * (60.0f / 100.0f))
        {
            aiTable = eAIType.Trying;
        }
        else
            aiTable = eAIType.Normal;

        aiTableID = gameData.GCastleData.GetGCastleData(gameData.EnemyGCastleID).Battle.AI.GetAI(aiTable);
    }
    bool CheckSP()
    {
        int id = 0;
        eGCastleSkillType type = eGCastleSkillType.Attack;

        //Debug.Log(aiTableID);
        //Debug.Log(gameData.GCastleData.AIData.GetData(aiTableID));
        //Debug.Log(gameData.GCastleData.AIData);
        //Debug.Log(gameData.GCastleData);
        //Debug.Log(gameData);
        while (true)//TODO : 적이 sP 회복스킬을 가지고 있는지 판정(실제 데이터가 있는지 없는 지 확인이 되지 않습니다. 임시로 때워둡니다. )
        {

            if (gameData.GCastleData.AIData.GetData(aiTableID).RateRecoverSP > 0.0f)
                break;
            else
                return false;

        }

        if (currentSP > 0)//현재 sp가 0보다 큼
        {
            if (currentSP <= maxSP * (gameData.GCastleData.AIData.GetData(aiTableID).RemainSP / 100))
            {
                //스킬 사용
                int randomRate = Random.Range(0, 100);
                if (randomRate < gameData.GCastleData.AIData.GetData(aiTableID).RateRecoverSP)
                {
                    //랜덤 확률이 지정된 스킬 확률 범위 안에 들어오면 사용
                    //Debug.Log("GCastle AI : Check SP  : Random : " + randomRate + " <  Rate : " + gameData.GCastleData.AIData.GetData(aiTableID).RateRecoverSP + " = Use SP Recover Skill");
                    return true;
                }
                else
                {
                    //Debug.Log("GCastle AI : Check SP  : Random : " + randomRate + " >  Rate : " + gameData.GCastleData.AIData.GetData(aiTableID).RateRecoverSP + " = No use SP Recover Skill");
                    return false;
                }
            }
            else
            {
                //Debug.Log("GCastle AI : Check SP  : CurrentSP : " + currentSP + " >  SP Limit  : " + gameData.GCastleData.AIData.GetData(aiTableID).RemainSP + " = No use SP Recover Skill");
                return false;
            }
        }
        else
        {
            //Debug.Log("GCastle AI : Check SP  : NO SP = No use SP Recover Skill");
            return false;
        }
    }

    /// <summary>
    /// GetSkillRecoverSP() SP회복 스킬의 레벨에 따른 사용확률, 
    /// 레벨에따른 방어 퍼센테이지 설정. 
    /// 
    /// 설탕? 3 드 ??? 14? 18 번 
    ///스킬 랭크 판정 
    ///적의 G 캐슬이 소지 스킬에서 사용하는 스킬 랭크를 설정합니다 
    ///스킬 랭크 1 ~ 5에 각각 사용 확률을 설정합니다 
    ///※ 합계가 100 %가되도록 데 ??로 설정합니다 
    ///※ 단 소지하지 않은 스킬 랭크는 제외하고 나머지 확률에서 판정 
    ///
    ///적의 G 캐슬의 나머지 SP 스킬 랭크에 설정된 스킬을 사용할 수 있는지 판정 
    ///설정에서 스킬 랭크의 스킬을 사용할 수없는 경우 
    ///설정에서 스킬 랭크를 하나 내려 다시 그 기술을 사용할 수 있는지 판정 
    ///사용할 수 있기까지 스킬 랭크를 낮추고 판정 계속 
    ///
    ///@param GC_PLAYER * pPlay [in] 플레이어 ?? 造体 
    ///@param GcNpcAi * pAi [in] 생각? 造体 (임시) 
    ///
