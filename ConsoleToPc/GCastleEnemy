    eGCastleSkillSubType GetSkillCategoryHeal()
    {
        int retVal = 0;
        eGCastleSkillSubType[] cate = new eGCastleSkillSubType[2];
        int[] value = new int[2];

        cate[0] = eGCastleSkillSubType.HealHP;
