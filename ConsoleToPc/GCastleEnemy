    void AIProcMain() // 기본 행동에 대한 설정. 
    {
        StartCoroutine(AIMainThread());
    }
    /// <summary>
    /// AIMainThread() : 스킬 로드와 장전을 하여 대기 할 수 있도록 함. 
    /// </summary>
    /// <returns></returns>
    IEnumerator AIMainThread()
    {
        bool flag = true;
        AITableSet();

        if (aiTable == eAIType.AIType_UnKnown)//실제로는 AI 테이블이 로딩되어있는가를 체크하여 없으면 로딩. 
        {//ai 테이블이 없는 경우 항상 공격만 하게 됨. 
            flag = false;
            nextSkill = eGCastleSkillType.Attack;
        }
        
        
        while (flag)
        {
            if (CheckSP())//SP 회복이 필요한지 확인
            {
                nextSkill = eGCastleSkillType.RecoverSP;
                NextSkillSet(GetSkillRecoverSP());
            }
            else
            {//SP회복 외의 다른 기술 사용
                skillType = GetSkillType();

                switch (skillType)//각각에 따른 스킬 사용함수. 
                {
                    case eGCastleSkillType.Attack:
                        nextSkill = eGCastleSkillType.Attack;
                        NextSkillSet(GetSkillAttack());
                        break;
                    case eGCastleSkillType.Buff:
                        nextSkill = eGCastleSkillType.Buff;
                        NextSkillSet(GetSkillBuff());                
                        break;
                        //TODO : 버프함수, 힐 관련 함수 내용 만들것.
                    case eGCastleSkillType.Heal:
                        nextSkill = eGCastleSkillType.Heal;
                        NextSkillSet(GetSkillHeal());
                        break;
                }
            }

            if (nextSkill != eGCastleSkillType.GCastleSkillType_UnKnown)
            {
                flag = false;
            }
            yield return new WaitForFixedUpdate();
        }
    }

