    eGCastleSkillSubType GetSkillCategoryAttack()
    {
        eGCastleSkillSubType[] subType = new eGCastleSkillSubType[3];
        int[] value = new int[3];

        subType[0] = eGCastleSkillSubType.Attack;
        value[0] = gameData.GCastleData.AIData.GetData(aiTableID).RateSubTypeAttack;
        subType[1] = eGCastleSkillSubType.Reflect;
        value[1] = gameData.GCastleData.AIData.GetData(aiTableID).RateSubTypeReflect;
        subType[2] = eGCastleSkillSubType.Pierce;
        value[2] = gameData.GCastleData.AIData.GetData(aiTableID).RateSubTypePierce;

        int rand_max = value[0] + value[1] + value[2];

        int rand = Random.Range(0, rand_max);

        int pos = 0;
        for (pos = 0; pos < 3; pos++)
        {
            if (rand < value[pos])
            {
                return subType[pos];
            }
            rand -= value[pos];
        }
        return eGCastleSkillSubType.Attack;
    }
