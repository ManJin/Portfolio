    eGCastleSkillSubType GetSkillCategoryBuff()
    {
        eGCastleSkillSubType[] cate = new eGCastleSkillSubType[3];
        int[] value = new int[3];
        cate[0] = eGCastleSkillSubType.Buff;
        value[0] = gameData.GCastleData.AIData.GetData(aiTableID).RateSubTypeBuff;//rateCateForce
        cate[1] = eGCastleSkillSubType.AbsorbSP;
        value[1] = gameData.GCastleData.AIData.GetData(aiTableID).RateSubTypeAbsorbSP;//rateCateAbsSP;
        cate[2] = eGCastleSkillSubType.FastAttack;
        value[2] = gameData.GCastleData.AIData.GetData(aiTableID).RateSubTypeFastAttack;//rateCateFastAttack;

        if (CheckEnhenceMax())//한계 강회된 경우 강회 제외
        {
            value[0] = 0;
        }

        int rand_max = value[0] + value[1] + value[2];
        int rand = Random.Range(0, rand_max);
        int pos = 0;

        for (pos = 0; pos < 3; pos++)
        {
            if (rand < value[pos])
            {
                return cate[pos];
            }
            rand -= value[pos];
        }
        return eGCastleSkillSubType.Buff;
    }

