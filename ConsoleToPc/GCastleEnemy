    /// </summary>
    /// <returns></returns>
    int GetSkillRecoverSP()
    {
        return GetUseSkill(eGCastleSkillSubType.HealSP);
    }
    int GetUseSkill(eGCastleSkillSubType subType)
    {
        decimal hp_now = 0;
        decimal hp_cost = 0;
        decimal sp_now = 0;
        decimal sp_cost = 0;
        hp_now = currentHP;
        sp_now = currentSP;

        int[] rateVals = new int[(int)eGCastleSkillType.GCastleSkillType_EndofType];
        eGCastleSkillRank[] rateRanks = new eGCastleSkillRank[(int)eGCastleSkillRank.GCastleSkillRankType_EndofType];
        int[] rateIDs = new int[(int)eGCastleSkillRank.GCastleSkillRankType_EndofType];
        int ratePos = 0;

        int rand_max = 0;
        eGCastleSkillRank rank;
        int id = 0;

        bool usable = false;

        for (rank = eGCastleSkillRank.Rank1; rank < eGCastleSkillRank.GCastleSkillRankType_EndofType; rank++)
        {
            skillType = eGCastleSkillType.Attack;
            while (true)
            {
                id = gameData.GCastleData.SkillData.GetGCastleSkillID(skillType, subType, rank);
                //Debug.Log("Before : " + skillType);
                if (id > 0)//스킬이 존재하는가
                {
                    //db에서 스킬데이타 가져옴
                    hp_cost = gameData.GCastleData.SkillData.GetGCastleSkillData(id).CostHP;//사용 hp cost
                    sp_cost = gameData.GCastleData.SkillData.GetGCastleSkillData(id).CostSP;//sp cost
                    //Debug.Log("cost sp : " + sp_cost + " , hp : " + hp_cost);
                    usable = false;

                    if (subType == eGCastleSkillSubType.HealSP)
                    {
                        if (hp_now > hp_cost)
                            usable = true;
                    }
                    else
                    {
                        if (sp_now >= sp_cost)
                            usable = true;
                    }
                    if (usable)
                    {
                        rateVals[ratePos] = gameData.GCastleData.AIData.GetData(enemyCastle.Battle.AI.GetAI(aiTable)).GetRate_SkillRank((int)rank) ;//aidml 스킬랭크를 가져옴
                        rateRanks[ratePos] = rank;
                        rateIDs[ratePos] = id;
                        rand_max += rateVals[ratePos];
                        //Debug.Log("GCastle Skill Usable : " + gameData.GCastleData.SkillData.GetGCastleSkillData(id).Name +", "+ gameData.GCastleData.SkillData.GetGCastleSkillData(id).CostHP +", "+ gameData.GCastleData.SkillData.GetGCastleSkillData(id).CostSP + ", " + ratePos + ", " +  rateVals[ratePos] );
                        ratePos++;
                        break;
                    }
                    else
                    {
                        //Debug.Log("GCastle Skill No Usable : " + gameData.GCastleData.SkillData.GetGCastleSkillData(id).Name + ", " + gameData.GCastleData.SkillData.GetGCastleSkillData(id).CostHP + ", " + gameData.GCastleData.SkillData.GetGCastleSkillData(id).CostSP + ", " + ratePos + ", " + rateVals[ratePos]);
                    }
                }
                skillType++;
                //Debug.Log("After : " + skillType);
                if (skillType >= eGCastleSkillType.GCastleSkillType_EndofType)
                    break;
            }
        }

        if (rand_max <= 0)
            return 0;//사용불가

        int rand = Random.Range(0, rand_max);
        int pos = 0;
        for (pos = 0; pos < ratePos; pos++)
        {
            //db에서 스킬 가져옴 
            if (rand < rateVals[pos])
            {
                //사용될 스킬을 db에서 가져옴
                Debug.Log("GCastle Skill Selected : " + gameData.GCastleData.SkillData.GetGCastleSkillData(rateIDs[pos]).Name);
                for (eGCastleSkillType j = eGCastleSkillType.GCastleSkillType_UnKnown; j < eGCastleSkillType.GCastleSkillType_EndofType; j++)
                {
                    //캐릭터의 개방된 스킬 중 해당하는 리스트가 있는지 검사. 
                    int length = GetCategoryCount(j);
                    for (int i = 0; i < length; i++)
                    {
                        if (rateIDs[pos] == OpenSkillIDs[i])
                            return rateIDs[pos];
                        else if (i == length - 1)
                        {
                            return 0;
                        }
                    }
                }
                //gameData.GCastleData.SkillData.GetGCastleSkillData(openedSkills[i]);
                return rateIDs[pos];
            }
            rand -= rateVals[pos];
        }
        return 0;
    }


