        // ŔĚČÄ ľĆ·ˇł»żë ŔĚÇŕ. 
        //Debug.Log("14");
        if (_state != WodenDollState.GameClear)
        {
            _state = WodenDollState.Idle;
            dollMoveEnabled = false;
            moveHorizentalDir = 0;
            moveVerticalDir = 0;
            targetDestination = Vector3.zero;
            SetRoomIncludeEnemy();
        }

    }
    protected override void Attack()
    {
        if (suicide)
        {
            GameContext gc = GameContext.GetInstance;
            Character ann = gc.stage.mainCharacter;
            ann.AcrossMarionette();
        }
    }

    protected override void Sleep()
    {
        SetRoomIncludeEnemy();
        if (roomIncludeDoll != null)
        {
            GameObject ventilatroObj = roomIncludeDoll.GetRoomObject(RoomObject.ObjectType.Ventilator);
            if( ventilatroObj != null )
            {
                Ventilator ven = ventilatroObj.GetComponent<Ventilator>();
                if (!ven.IsExistGas)
                    _state = WodenDollState.Awake;
            }
            
        }
    }

    public bool GameClear()
    {
        if (_state == WodenDollState.Dead || _state == WodenDollState.GameClear)
        {
            return true;
        }
        else if (_state != WodenDollState.Attack)
        {
            Room annRoom = RoomManager.GetInstance.GetFocusRoom();
            if (roomIncludeDoll.id == annRoom.id)
            {
                _state = WodenDollState.Attack;
                return false;
            }
            _state = WodenDollState.GameClear;
            return true;
        }

        return false;
    }
}

public enum WodenDollState
{
    Complete,
    Move,
    Idle,
    Attack,
    Faint,
    Sleep,
    Awake,
    JumpUp,
    JumpDown,
    Dead,
    Stop,
    GameClear,
    MoveLeft,
    MoveRight,
    UpStop,
}
