    {
        coinData.GetCoinInfo(id, out coinNumber, out coinPrice);
    }

    bool UseIAPIngameItem(IAPItem itemType)
    {
        GameContext gc = GameContext.GetInstance;
        Character ann = gc.stage.mainCharacter;
        bool useItem = false;

        switch (itemType)
        {
            case IAPItem.Bless:
                if (ann.UseInappItemBlessing())
                    useItem = true;
                break;
            case IAPItem.Bomb:
                if (ann.UseInappItemBomb())
                    useItem = true;
                break;
            case IAPItem.Phone:
                if (ann.UseInappItemCellPhone())
                    useItem = true;
                break;
            case IAPItem.Magnetic:
                if (ann.UseInappItemMagnetic())
                    useItem = true;
                break;
            case IAPItem.Masterkey:
                if (ann.UseInappItemMasterkey())
                    useItem = true;
                break;
            case IAPItem.RemoteGear:
                if (ann.UseInappItemRemoteGear())
                    useItem = true;
                break;
            case IAPItem.Compass:
                if (ann.UseInappItemCompass())
                    useItem = true;
                break;
            case IAPItem.Remover:
                if (ann.UseInappItemRemover())
                    useItem = true;
                break;
            default:
                break;
        }

        return useItem;
    }

    IAPManager()
    {
        itemData = new IAPSellGoodsData();
        coinData = new CoinPriceData();
    }
    
    IAPSellGoodsData itemData = null;
    CoinPriceData coinData = null;
