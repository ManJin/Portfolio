        public void ChangeLeader( long UserKey  , bool bIsJumpMaster , AxPlayer myPlayer )
        {
            AxPlayer player = GetPlayer( UserKey );

            if( player == null )
                return;

            List<AxPlayer> playerList = GetTeam( player.GroupKey );

            if( playerList == null )
                return;

            AxPlayer master = null;
            for( int i = 0 ; i < playerList.Count ; i++ )
            {
                if( playerList[ i ].WorldKey == UserKey )
                {
                    playerList[ i ].SetJumpMaster( true );
                    master = playerList[ i ];
                    //playerList[ i ].transform.SetParent( this.transform );
                    SetJumpMaster( playerList[ i ] );
                }
                else if( playerList[ i ].IsJumpMaster() )
                {
                    playerList[ i ].SetJumpMaster( false );
                }
            }

            if (master)
            {
                for (int i = 0; i < playerList.Count; i++)
                {
                    playerList[i].SetJumpMasterName(master.Name);
                }
            }

            for ( int i = 0 ; i < playerList.Count ; i++ )
            {
                //if( playerList[ i ].IsFollow() )
                //    playerList[ i ].transform.SetParent( master.transform );
            }

            AxInGameEvent.Singleton.EventParam_ChangeJumpMaster.bIsMaster = bIsJumpMaster;
            AxInGameEvent.Singleton.EventParam_ChangeJumpMaster.IsSolo = myPlayer.IsSoloJump();
            AxInGameEvent.Singleton.EventParam_ChangeJumpMaster.PreMasterName = master != null ? master.PreJumpMasterName : string.Empty;
            AxInGameEvent.Singleton.EventParam_ChangeJumpMaster.MasterName = master != null ? master.Name : string.Empty;
            AxInGameEvent.Singleton.EventParam_ChangeJumpMaster.JumpMasterWorldKey = master != null ? master.WorldKey : 0;
            AxInGameEvent.Singleton.EventParam_ChangeJumpMaster.IsCameraTargetPlayerInAirplane = myPlayer.Property.IsAirPlane;

            AxInGameEvent.Singleton.SendEvent( AxInGameEventType.ChangeJumpMaster , AxInGameEvent.Singleton.EventParam_ChangeJumpMaster );
            
            if( myPlayer.IsFollow() )
                AxInGameEvent.Singleton.SendEvent( AxInGameEventType.Follow , null );
        }

        public void SetSoloAll( long GroupKey )
        {
            List<AxPlayer> playerList = GetTeam( GroupKey );

            for( int i = 0 ; i < playerList.Count ; i++ )
            {
                playerList[ i ].SetSolo();

                if( playerList[ i ].WorldKey == MyPlayer.WorldKey )
                {
                    AxInGameEvent.Singleton.EventParam_SoloFall.IsInAirplane = playerList[ i ].Property.IsAirPlane;
                    AxInGameEvent.Singleton.SendEvent( AxInGameEventType.SoloFall , AxInGameEvent.Singleton.EventParam_SoloFall );

                    AxCameraController.Singleton.SetSolo();
                }
            }
        }

        public void SetSolo( long UserKey , long MyKey )
        {
            AxPlayer player = GetPlayer( UserKey );

            player.SetSolo();            

            List<AxPlayer> playerList = GetTeam( player.GroupKey );

            if( playerList == null )
                return;            
         
            //! 마스터가 혼자뛰게됬을경우 마스터도 솔로로변경..
            for( int i = 0 ; i < playerList.Count ; i++ )
            {
                if( playerList[ i ].IsFollow() )
                    return;
            }

            for( int i = 0 ; i < playerList.Count ; i++ )
            {
                if( playerList[ i ].IsJumpMaster() )
                {
                    playerList[ i ].SetSolo();
                    if( playerList[ i ].WorldKey == MyKey )
                    {
                        AxInGameEvent.Singleton.EventParam_SoloFall.IsInAirplane = playerList[i].Property.IsAirPlane;
                        AxInGameEvent.Singleton.SendEvent( AxInGameEventType.SoloFall , AxInGameEvent.Singleton.EventParam_SoloFall);
                    }
                }
            }
           
        }

        public void CalculateJumpMasterPosition( long WorldKey , Vector3 MasterPosition , Quaternion rot )
        {
            int number = 1;

            for( int i = 0 ; i < AxPlayerManager.Singleton.MyTeamPlayers.Count ; i++ )
            {
                if( AxPlayerManager.Singleton.MyTeamPlayers[ i ].WorldKey == WorldKey )
                    continue;

                
                if( AxPlayerManager.Singleton.MyTeamPlayers[ i ].IsFollow() )
                {
                    Vector3 position = MasterPosition;
                    position.x = number % 2 == 0 ? position.x + 2 : position.x - 2;

                    Collider[] col = Physics.OverlapSphere( position , 2 , AxPhysicsUtil.MapCheckLayer );

                    if( col.Length > 0 )
                    {
                        if( WorldKey == MyPlayer.WorldKey )
                        {
                            AxInGame.Singleton.GetMyController().SoloFall();                            
                        }
                        return;
                    }

                    AxPlayerManager.Singleton.MyTeamPlayers[ i ].transform.position = position;
                    AxPlayerManager.Singleton.MyTeamPlayers[ i ].SetPosition( position );
                    AxPlayerManager.Singleton.MyTeamPlayers[ i ].transform.rotation = rot;

                    number++;
                }
            }
        }

        public int GetLiveUserCount()
        {
            int count = 0;

            if (_players != null)
            {
                for (int i = 0; i < _players.Count; ++i)
                {
                    if (_players[i] == null)
                        continue;

                    if (_players[i].Property.IsDead)
                        continue;

                    ++count;
                }
            }

            return count;
        }
        
        private void CullingPlayer(CullingGroupEvent ev)
        {
            if (ev.index < 0 || ev.index >= _dicPlayers.Count)
                return;

            AxPlayer[] playerList = _dicPlayers.Values.ToArray();

            var player = playerList[ev.index];

            if (player != null)
            {
                if (player.ContinueProcess() == false)
                    return;

                if (player.Property.IsCameraTarget || player.Property.IsDead || player.Property.IsAirPlane)
                    return;
                
                if (ev.currentDistance <= 0 || (ev.isVisible && ev.currentDistance <= 2))
                {
                    player.CharacterModelOn();
                    player.PlayFootSoundCulling(false);
                }
                else
                {
                    player.CharacterModelOff();

                    if(ev.currentDistance == 1)
                        player.PlayFootSoundCulling(true);
                    else
                        player.PlayFootSoundCulling(false);
                }
            }
        }

