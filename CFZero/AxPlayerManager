        public void Clear()
        {
            RemovePlayers.Clear();

            for (int i = 0; i < _players.Count; ++i)
            {
                DestoryPlayer(_players[i]);
            }

            foreach (var val in dicTeamPlayer)
            {
                if (val.Value != null)
                    val.Value.Clear();
            }

            dicTeamPlayer.Clear();
            _players.Clear();
            _dicPlayers.Clear();

            MyTeamPlayers = null;
            MyPlayer = null;
            JumpMaster = null;



        }

        private void DestoryPlayer(AxPlayer player)
        {
            if (player == null)
                return;

            player.Clear();
            Destroy(player.gameObject);
        }

