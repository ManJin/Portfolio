        public int GetTeamArrayIndex( long GroupKey , Int64 playerID )
        {
            if( dicTeamPlayer.ContainsKey( GroupKey ) == false )
                return 0;

            List<AxPlayer> list = dicTeamPlayer[ GroupKey ];

            for( int i = 0 ; i < list.Count ; i++ )
            {
                if( list[ i ].WorldKey == playerID )
                    return i;
            }

            return 0;
        }


