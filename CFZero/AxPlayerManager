        public int GetLiveTeamCount()
        {
            if (dicTeamPlayer == null)
                return 0;

            int count = 0;

            foreach (var val in dicTeamPlayer)
            {
                var team = val.Value;
                if (team == null)
                    continue;

                for (int i = 0; i < team.Count; ++i)
                {
                    var player = team[i];
                    if (player == null)
                        continue;

                    if (player.Property.state == eWORLD_USER_STATE.ALIVE_USER_STATE)
                    {
                        ++count;
                        break;
                    }
                }
            }

            return count;
        }

        public IEnumerator LoadAllPlayer( Action<float> onProgress )
        {
            int loadingCount = 0;
            Debug.LogError("loading Start");
            bLoading = true;



            while (loadingCount < _players.Count)
            {
                yield return _players[loadingCount].LoadCharacter();
                ++loadingCount;

                //Debug.LogError("Player loading Start :" + loadingCount.ToString());
                if (onProgress != null)
                    onProgress((float)loadingCount / (float)_players.Count);                
            }
            //foreach ( var player in _players )
            //{
            //    yield return player.LoadCharacter();
            //    ++loadingCount;

            //    Debug.LogError("Player loading Start :" + loadingCount.ToString());
            //    if ( onProgress != null )
            //        onProgress( (float)loadingCount / (float)_players.Count );
            //}


            bLoading = false;

            for( int i=0; i < RemovePlayers.Count; i++)
            {
                RemovePlayer(RemovePlayers[i]);
            }
            yield return null;
        }


