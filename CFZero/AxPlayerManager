        public AxPlayer AddPlayer( long worldKey , int charID , string name, long GroupKey , string countryCode, long exp )
        {
	        if (_dicPlayers.ContainsKey(worldKey))
	        {
		        Debug.LogErrorFormat("중복된 플레이어가 있습니다. : {0}:{1}", worldKey, name);
		        return null;
	        }

            var go = new GameObject();
            go.name = string.Format( "AxPlayer_{0}" , name );
            go.transform.parent = transform;

            var newPlayer = go.AddComponent<AxPlayer>();
            
            newPlayer.Initialize(worldKey, charID, name, GroupKey, countryCode, exp);

            Debug.LogFormat("AxPlayer_{0}, worldKey_{1}", name, worldKey);
            _players.Add( newPlayer );
            _dicPlayers.Add( worldKey , newPlayer );

            List<AxPlayer> playerList;
            if( dicTeamPlayer.TryGetValue( GroupKey , out playerList ) )
            {
                playerList.Add( newPlayer );

                playerList.Sort(delegate(AxPlayer a, AxPlayer b)
                {
                    if (a.WorldKey > b.WorldKey)
                    {
                        return 1;
                    }
                    else if (a.WorldKey < b.WorldKey)
                    {
                        return -1;
                    }

                    return 0;
                });
                
	            for (int index = 0; index < playerList.Count; ++index)
                    playerList[index].PartyIndex = index;
            }
            else
            {
                playerList = new List<AxPlayer>();
                playerList.Add( newPlayer );
                dicTeamPlayer.Add( GroupKey , playerList );
            }

            playersCulling.SetPlayerList(_dicPlayers.Values.ToArray());

            return newPlayer;
        }
        
