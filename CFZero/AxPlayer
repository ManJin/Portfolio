    public void AddSkillEffect(List<long> _sameGroupList)
    {
        for (int i = 0; i < _sameGroupList.Count; i++)
        {
            AxPlayer effectOwner = AxPlayerManager.Singleton.GetPlayer(_sameGroupList[i]);

            // 힐에서 케릭터의 몸에 붙는 이펙트와 스크린 이펙트는 각각의 스킨에 맞게 동적 생성 한다.
            if (effectOwner.PlayerClass == (int)CFW.UI.Lobby.CustomControl.AXCharacterClass.eAXCharacterClass.Supporter)
            {
                if (dicHealEffect.ContainsKey(effectOwner.CharID))
                    continue;

                AxEffectObjectManager.EffectResource effectResource = AxEffectObjectManager.Singleton.GetSkillEffectPath(effectOwner.CharID, eAxSkillEffectType.Active);
                //"/Effects/Skill/AX_EFFECT_SKILL_HEAL_HUMAN";
                string EffectName = SkillEffectPath.GetSkillEffectPath(effectResource.EffectResource_2);

                GameObject obj = Resources.Load(EffectName) as GameObject;

                GameObject HealEffect = Instantiate(obj);

                HealEffect.transform.parent = transform;
                HealEffect.transform.position = transform.position;
                HealEffect.transform.rotation = transform.rotation;
                HealEffect.transform.localScale = Vector3.one;
                HealEffect.SetActive(false);

                dicHealEffect.Add(effectOwner.CharID, HealEffect);

                //"CFA/Effects/Skill/AX_EFFECT_SKILL_SCREEN_HEAL";
                string screenEffectName = SkillEffectPath.GetSkillEffectPath(effectResource.EffectResource_3);

                dicScreenHealEffect.Add(effectOwner.CharID, screenEffectName);
            }
        }
    }

