    public void DoUseItemCast(bool bStart, long worldKey, float recoveryItemSpeedUpRatio, Action onEnd)
    {//
        
        var item = _inventory.GetItem(worldKey);
        if (item == null)
            return;

        BR_ConsumableItemEntry? entry = DataTableManager.BR_ConsumableItemTable.GetEntry(item.ID);
        if (entry.HasValue == false)
            return;

        //Debug.Log("DoUseItemCast." + Name + " : " + bStart + " : " + Property.IsArms + " : " + Property.IsUnarms);

        Property.IsUseItem = bStart;
        
        Property.UseItemType = DataTableManager.BR_ConsumableAnimationTable.GetTypeValue(item.ID);
        character.SetQVLayerWeight(AnimatorValues.UpperLayer, 1f);

        if (bStart)
        {
            Property.UseItemID = item.ID;
            _inventory.SetCurrentWeapon(WeaponSlot.Item);

            if (Property.IsCameraTarget)
            {
                var skill = _inventory.GetSavedSkill();
                if (skill != null)
                    character.SkillToBack(skill, null);
                AxCameraController.Singleton.SetPvFOV(CameraValues.ItemPVFov);

                //OffHideEffect();
            }
            //Debug.LogError("_" + _inventory.GetCurrentSlot() + " : " + _inventory.GetPrevSlot());


            character.SetPVBool(AnimatorValues.hash_UseItem, true);
            if (Property.UseItemType == 0)
                UseItemStart(0, 0);
            else
                UsePDAStart(0, 0);
        }
        else //! 완료 
        {
            Property.UseItemID = 0;
            if (Property.UseItemType == 0)
                UseItemEnd(onEnd);
            else
                UsePDAEnd(onEnd);

            _inventory.RemoveItem(worldKey, item.ID, 1, true);
        }
        
        Eventer.EventParam_UseItemCast.IsStart = bStart;
        Eventer.EventParam_UseItemCast.ItemID = item.ID;

        Eventer.EventParam_UseItemCast.CastingSecond = entry.Value.Casting;

        switch ((ConsumableItemType)entry.Value.Type)
        {
            case ConsumableItemType.Heel:
                {
                    Eventer.EventParam_UseItemCast.CastingSecond = entry.Value.Casting * recoveryItemSpeedUpRatio;
                }
                break;
        }
        
        Eventer.EventParam_UseItemCast.Recovery = entry.Value.Recovery;
        Eventer.SendEvent(AxPlayerEventType.UseItemCast, Eventer.EventParam_UseItemCast);
    }

