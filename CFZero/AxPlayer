    public void DoInvenChangePosition(long worldKey, int id, eBATTLEGROUND_EQUIP position, Action onChanged)
    {
        var slot = BRPlayerUtil.GetWeaponSlotByBATTLEGROUND_EQUIP(position);
        var item = _inventory.GetItem(worldKey);
	    if (item == null )
	    {
		    if (id != 0)
		    {
			    item = AxItemManager.CreateItem(worldKey, id, 1);
		    }
		    else
		    {
			    return;
		    }
	    }

        if (item is AxWeaponParts)
        {
            if (position == eBATTLEGROUND_EQUIP.eBG_INVENTORY_EQUIP)
            {
                _inventory.PartsUnEquip(worldKey, Property.IsCameraTarget);
                _inventory.AddToBag(item);
            }
            else if (position == eBATTLEGROUND_EQUIP.eBG_WEPON1_EQUIP ||
                     position == eBATTLEGROUND_EQUIP.eBG_WEPON2_EQUIP)
            {
                var _parts = ((AxWeaponParts)item).WeaponItem;
                var prevSlot = WeaponSlot.None;

                if (_parts != null)
                {
                    prevSlot = ((AxWeaponParts)item).WeaponItem.CurrentSlot;
                }

                var partsType = BRPlayerUtil.GetWeaponPartsTypeByEquipPosition(item.ItemEntry.EquipPosition);
                var oldParts = _inventory.GetEquipParts(slot, partsType);


                if (oldParts != null)
                {
                    _inventory.PartsUnEquip(oldParts.WorldKey, Property.IsCameraTarget, false);
                }

                if (prevSlot == WeaponSlot.None)
                {
                    _inventory.RemoveBag(item);
                }
                else
                {
                    _inventory.PartsUnEquip(item.WorldKey, Property.IsCameraTarget);
                }

                _inventory.PartsEquip(item as AxWeaponParts, slot);

                if (oldParts != null)
                {
                    if (prevSlot == WeaponSlot.None)
                        _inventory.AddToBag(oldParts);
                    else
                    {
						var reversedSlot = slot == WeaponSlot.First_Rifle ? WeaponSlot.Second_Rifle : WeaponSlot.First_Rifle;
						var selectedSlotsWeapon = _inventory.GetWeapon(reversedSlot);
						if (selectedSlotsWeapon == null)
							_inventory.AddToBag(oldParts);

						if (IsApplicableParts(selectedSlotsWeapon.ID, oldParts) == true)
							_inventory.PartsEquip(oldParts, prevSlot);
						else
							_inventory.AddToBag(oldParts);
					}
                }
            }
        }
        else if (item is AxWeapon)
        {
            switch (position)
            {
                case eBATTLEGROUND_EQUIP.eBG_THROWINGWEPON_EQUIP:
                    {
                        var preThrow = _inventory.GetWeapon(WeaponSlot.Fifth_Throw);
                        if (preThrow != null)
                        {
                            _inventory.WeaponUnEquip(preThrow.WorldKey);
                            _inventory.AddToBag(preThrow);
                        }

                        AxWeapon weapon = _inventory.GetItem(worldKey) as AxWeapon;

                        WeaponEquip(weapon as AxWeapon, WeaponSlot.Fifth_Throw, true);
                        //weapon.ShowPV(false);
                        //weapon.ShowQV(false);
                        
                        if (_inventory.GetCurrentSlot() != WeaponSlot.First_Rifle &&
                            _inventory.GetCurrentSlot() != WeaponSlot.Second_Rifle)
                        {
                            DoInvenPickup(weapon as AxWeapon, eBATTLEGROUND_EQUIP.eBG_THROWINGWEPON_EQUIP,
                                    () => { DoWeaponSelect(worldKey, false, null); });
                            //DoWeaponSelect(worldKey, false, null);
                        }
                    }
                    break;

                case eBATTLEGROUND_EQUIP.eBG_INVENTORY_EQUIP:
                    {
                        AxWeapon weapon = _inventory.GetItem(worldKey) as AxWeapon;
                        if (weapon == null)
                            return;

                        if (weapon.Slot == WeaponSlot.Fifth_Throw)
                        {
                            _inventory.WeaponUnEquip(worldKey);
                            _inventory.AddToBag(item);

                            switch (_inventory.GetCurrentSlot())
                            {
                                case WeaponSlot.Fifth_Throw:
                                    {
                                        var preWeapon = _inventory.GetWeapon(_inventory.GetPrevSlot());
                                        if (preWeapon != null)
                                        {
                                            DoWeaponSelect(preWeapon.WorldKey, false, null);
                                        }
                                        else
                                        {
                                            var hand = _inventory.GetWeapon(WeaponSlot.Fourth_Melee);
                                            if (hand != null)
                                                DoWeaponSelect(hand.WorldKey, false, null);
                                        }
                                    }
                                    break;

                                case WeaponSlot.Fourth_Melee:
                                    {
                                        DoWeaponSelect(weapon.WorldKey, false, null);
                                    }
                                    break;
                            }
                        }
                    }
                    break;

                default:
                    {
                        //var prevSlot = GetCurrentWeaponSlot();
                        _inventory.WeaponChange(slot, DoWeaponSelect);
                    }
                    break;
            }
        }
    }

	bool IsApplicableParts(int weaponIndex, AxWeaponParts parts)
	{
		switch (parts.PartsType)
		{
			case WeaponPartsType.Magazine:
					return DataTableManager.BR_WeaponTable.GetUseMagazinePartsType(weaponIndex, parts.ID) != CFBR.Shared.Enum.Attachment_Magazine.None;

			case WeaponPartsType.Stocks:
					return DataTableManager.BR_WeaponTable.GetUseStockType(weaponIndex, parts.ID) != CFBR.Shared.Enum.Attachment_Stock.None;

			case WeaponPartsType.Muzzle:
					return DataTableManager.BR_WeaponTable.GetUseMuzzlePartsType(weaponIndex, parts.ID) != CFBR.Shared.Enum.Attachment_MuzzlePartsType.None;

			case WeaponPartsType.UpperRail:
					return DataTableManager.BR_WeaponTable.GetUseUpperRailType(weaponIndex, parts.ID) != CFBR.Shared.Enum.Attachment_UpperRailType.IronSight;

			case WeaponPartsType.Grips:
					return DataTableManager.BR_WeaponTable.GetUseGripType(weaponIndex, parts.ID) != CFBR.Shared.Enum.Attachment_GripType.None;
		}

		return false;
	}


