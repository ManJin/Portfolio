    public void On_HealEffect(bool val, long GroupKey, long worldKey)
    {
        if (dicHealEffect == null || dicHealEffect.Count <= 0)
            return;

        if (Property.IsDead) return;

        //월드키가 0보다 작으면 초기화
        if (worldKey < 0)
        {
            foreach (var item in dicHealEffect)
            {
                item.Value.SetActive(false);
            }

            foreach (var item in dicScreenHealEffect)
            {
                ScreenEffectManager.Instance.StopHealEffect(item.Value);
            }
        }
        else
        {
            AxPlayer skillOwner = AxPlayerManager.Singleton.GetPlayer(worldKey);
            GameObject HealEffect = dicHealEffect[skillOwner.CharID];

            string screenEffectName = dicScreenHealEffect[skillOwner.CharID];

            if (_groupKey == GroupKey)
            {
                HealEffect.SetActive(val);

                if (Property.IsCameraTarget == true && ScreenEffectManager.Instance != null)
                {
                    if (val == true)
                    {
                        ScreenEffectManager.Instance.PlayHealEffect(screenEffectName);
                    }
                    else
                        ScreenEffectManager.Instance.StopHealEffect(screenEffectName);
                }
            }
            else
            {
                if (val == false)
                {
                    if (GroupKey == 0)
                    {
                        HealEffect.SetActive(false);
                        if (ScreenEffectManager.Instance != null)
                            ScreenEffectManager.Instance.StopHealEffect(screenEffectName);
                    }
                }
            }
        }
    }

    public void SetHealEffectLayer(bool val)
    {
        int layer;

        if (val)
            layer = LayerMask.NameToLayer("QV");
        else
            layer = LayerMask.NameToLayer("Hidden");

        foreach(var item in dicHealEffect)
        {
            GameObject HealEffect = item.Value;

            HealEffect.gameObject.layer = layer;
            Transform[] HealTrans = HealEffect.GetComponentsInChildren<Transform>();
            for (int i = 0; i < HealTrans.Length; ++i)
                HealTrans[i].gameObject.layer = layer;
        }
    }

