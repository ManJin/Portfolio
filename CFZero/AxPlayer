    public bool DoEmoteStart(int id , Action EndAction)
    {
        EmoteEndAction = EndAction;
        if (!ContinueProcess()) return false;
        if (Property.IsGroggy) return false;
        if (Property.IsGroggyCare) return false;
        if (Property.IsGroggyCareEnd) return false;
        if (Property.IsDead) return false;
        if (Property.IsParkour) return false;
        if (Property.IsClimbing) return false;
        if (Property.IsZipLine) return false;
        if (Property.IsUseItem) return false;
        if (Property.IsReload) return false;
        if (Property.IsSkillReady) return false;
        if (Property.IsSkillReserved) return false;
        if (Property.IsSkyDive) return false;
        if (Property.IsZoom) return false;
        if (Property.IsSliding) return false;
        if (Property.IsThrowReady) return false;
        if (Property.IsThrowReserved) return false;
        if (Property.IsArms) return false;
        if (Property.IsUnarms) return false;

        if (IsThrowAnimationWorks() || IsThrowEndAnimationWorks()) return false;
        if (IsFireAnimationWorks()) return false;
        if (IsArmsAnimationWorks()) return false;
        if (IsUsingSkills() ||  IsUseSkillEnd() || IsSingleMotionSkill()) return false;
        if (IsUsePDA()) return false;
        if (IsChangingItem() || IsChangingSkill()) return false;
        if (IsGroggyCareActorAnimationWorks() || IsGroggyCareTargetAnimationWorks()) return false;
        if (character.IsReloadAnimationWorks()) return false;

        //if (Property.IsRush )
        //{
        //    SetRush(false);
        //    //ActMove(Property.MoveDir);
        //    DoRush(false);//러쉬 제거 되어야 함. 
        //}


        //이펙트 및 사운드 캐릭터 단에서 틀어줄것. 
        if (Property.IsCameraTarget)
        {
            Eventer.SendEvent(AxPlayerEventType.EmoteStart, null);
            SetCharacterViewMode(CameraViewMode.QV);
        }
        
        //Property.MoveDir = 0;
        Property.IsEmoteMotion = true;
        Property.EmoteID = id;
        float blendID = DataTableManager.EmoteTable.GetBlendTreeType(Property.EmoteID);


        //저장된 이펙트 틀어줄 부분. 
        character.PlayEmoteSound(id);  

        Property.EmoteType = blendID;


        //Debug.Log("EmoteStart " + id + " : " + blendID);
        foreach (var emo in Emotedic)
        {
            //Debug.Log("EmoteStart " + emo.Value.Value + " : " + id);
            if (emo.Value.Value == Property.EmoteID)
            {
                
                emo.Value.ActiveObject();
            }
        }
        //Debug.LogErrorFormat("Emote Start : {0}, {1}" ,Time.realtimeSinceStartup, Name );
        //허리 로테이션 적용 해제 
        character.SlotToBack(_inventory.GetCurrentWeapon(), (int)_inventory.GetCurrentSlot());
        character.SkillToBack(_inventory.GetCurrentSkill(), null);
        character.SetQVLayerWeight(AnimatorValues.UpperLayer, 0f);
        character.EnableAim(false);
        character.InitBodyPosition();

        character.AnimateEmote(blendID, ()=> {
            if (Property.IsCameraTarget && Property.IsEmoteMotion)
            {
                if (EmoteEndAction != null)
                    EmoteEndAction();
                //DoEmoteEnd();
            }
        } , true );

        return true;
    }
    public void DoEmoteEnd( bool bCancel = false )
    {
        if (!ContinueProcess()) return;
        if (Property.IsDead) return;

        //Debug.Log("Emote End");

        foreach (var emo in Emotedic)
        {
            if (emo.Value.Value == Property.EmoteID)
            {
                //Debug.Log("EmoteStart " + id );
                emo.Value.DeactiveObject();
            }
        }

        character.StopEmoteSound(Property.EmoteID);
        Property.EmoteID = 0;

        if (Property.IsCameraTarget)
        {
            if(bCancel)
                Eventer.SendEvent(AxPlayerEventType.EmoteCancel, null);
            else
                Eventer.SendEvent(AxPlayerEventType.EmoteEnd, null);

            SetCharacterViewMode(CameraViewMode.PV);
        }
        
        Property.IsEmoteMotion = false;
        if(Property.IsUseSkill)
            character.SkillToHand(_inventory.GetCurrentSkill(), _inventory.GetCurrentWeapon(), _inventory.GetCurrentSlot(), null);
        else if (Property.IsUseItem)
            character.ItemToHand(AxAttachNode.RightHand, Property.UseItemType);
        else
            character.SlotToHand(_inventory.GetCurrentWeapon());

        character.SetQVLayerWeight(AnimatorValues.UpperLayer, 1f);

        //Debug.LogErrorFormat("Emote End : {0}, {1}", Time.realtimeSinceStartup, Name);
        character.InitBodyPosition();
        character.AnimateIdle(Property.IsSit, 0);
        character.EnableAim(true);
    }
    /// <summary>
    /// 줌 / 견착 동작
    /// </summary>
    /// <param name="val">시작 / 끝</param>
    /// <param name="zoomType">몇단계의 줌인지 </param>
    /// <param name="nLength"></param>
    /// <param name="normalizedTime"></param>
    public void DoZoom(bool val, int zoomType, float nLength, float normalizedTime)
    {
        if (!ContinueProcess())
        {
            //Debug.Log("Zoom ContinueProcess");
            return;
        }

        if (Property.IsGroggy)
        {
            //Debug.Log("Zoom Is Groggy");
            return;
        }

        if (Property.IsDead)
        {
            //Debug.Log("Zoom Is Dead");
            return;
        }
        if (character.IsFireable() == false && val == true)
        {
            //Debug.Log("Zoom IsFireable");
            return;
        }
        if (character.IsArmsAnimationWorks())
        {
            //Debug.Log("Zoom Is ArmsAnimationWorks");
            return;
        }


        if (val && Property.IsReload)
        {
            //Debug.Log("Zoom IsRelaod");
            return;
        }

        if (character.IsUseSkill())
            return;
        if (IsUseSkillEnd())
        {
            //Debug.Log("Zoom IsUseSkillEnd");
            return;
        }

        if (Property.IsSkillReserved)
            return;

        

        if (val == true && Property.IsRush == true)
        {
            SetRush(false);
            //ActMove(Property.MoveDir);
            DoRush(false);//러쉬 제거 되어야 함. 
        }

        if(Property.IsZoom == true && val == false)
            character.PlayAudioEvent(BRAudioEvent.EventType.ZoomOut_AX);
        else if(val == true)
            character.PlayAudioEvent(BRAudioEvent.EventType.ZoomIn_AX);

        //Debug.Log("DoZoom : " + val + " : " + Property.ZoomType + " : " + zoomType);
        Property.IsZoom = val;

        _calcZoomTypeAxis.SetTypeAxis(zoomType, Property.ZoomType);

        Vector3 pvPositionFov=Vector3.zero;
        if (val == true)
        {
            switch (GetCurrentWeaponUpperRailType())
            {
                case CFA.Shared.Enum.Attachment_UpperRailType.IronSight:
                    character.SetPVFloat(AnimatorValues.hash_UpperRailType, (float)Pv_Animator_UpperRailType.IronSight);
                    if (Property.IsCameraTarget)
                    {
                        pvPositionFov = GetCurrentWeapon().WeaponZoomOption.PvPosition_DefaultFOV;
                    }
                    break;
                case CFA.Shared.Enum.Attachment_UpperRailType.HoloSight:
                    character.SetPVFloat(AnimatorValues.hash_UpperRailType, (float)Pv_Animator_UpperRailType.HoloSight);
                    if (Property.IsCameraTarget)
                    { 
                        pvPositionFov = GetCurrentWeapon().WeaponZoomOption.PvPosition_HoloFOV;
                    }
                    break;
                case CFA.Shared.Enum.Attachment_UpperRailType.DotSight:
                    character.SetPVFloat(AnimatorValues.hash_UpperRailType, (float)Pv_Animator_UpperRailType.DotSight);
                    if (Property.IsCameraTarget)
                    { 
                        pvPositionFov = GetCurrentWeapon().WeaponZoomOption.PvPosition_DotFOV;
                    }
                    break;
                case CFA.Shared.Enum.Attachment_UpperRailType.Scope2x:
                    character.SetPVFloat(AnimatorValues.hash_UpperRailType, (float)Pv_Animator_UpperRailType.Scope2x);
                    if (Property.IsCameraTarget)
                    { 
                        pvPositionFov = GetCurrentWeapon().WeaponZoomOption.PvPosition_2XFOV;
                    }
                    break;
                case CFA.Shared.Enum.Attachment_UpperRailType.Scope4x:
                    character.SetPVFloat(AnimatorValues.hash_UpperRailType, (float)Pv_Animator_UpperRailType.Scope4x);
                    if (Property.IsCameraTarget)
                    { 
                        pvPositionFov = GetCurrentWeapon().WeaponZoomOption.PvPosition_4XFOV;
                    }
                    break;
            }
        }
        else
        {
            character.SetPVFloat(AnimatorValues.hash_UpperRailType, 0);
        }

        if (Property.IsCameraTarget)
        {
            Eventer.EventParam_Zoom.IsZoom = val;
            Eventer.EventParam_Zoom.UpperRailType = GetCurrentWeaponUpperRailType();
            Eventer.EventParam_Zoom.Fov = GetCurrentWeaponZoomFov();
            Eventer.EventParam_Zoom.PvFov = GetWeaponPvFov(val);
            Eventer.SendEvent(AxPlayerEventType.Zoom, Eventer.EventParam_Zoom);

            if (GetCurrentWeapon().WeaponParts[(int)WeaponPartsType.UpperRail])
            {
                if (GetCurrentWeapon().WeaponParts[(int)WeaponPartsType.UpperRail].UpperPartsZoomVisible != null)
                {
                    GetCurrentWeapon().WeaponParts[(int)WeaponPartsType.UpperRail].UpperPartsZoomVisible.Zoom(val);
                    if (val == true)
                        GetCurrentWeapon().WeaponParts[(int)WeaponPartsType.UpperRail].UpperPartsZoomVisible.SetReticleOffset(pvPositionFov);
                }
            }
        }

        DoWalk(val);
        //Debug.Log("DoZoom : " + val);
        character.AnimateZoomWeapon(GetCurrentWeapon(), 0, 0, val);


    }
    public float GetWeaponPvFov(bool zoom)
    {
        float pvFov = 0;
        if (GetCurrentWeapon() != null)
        {
            if (zoom == true)
            {
                switch (GetCurrentWeaponUpperRailType())
                {
                    case CFA.Shared.Enum.Attachment_UpperRailType.IronSight:
                        pvFov = GetCurrentWeapon().WeaponOption.PvZoom1DefaultFOV;
                        break;
                    case CFA.Shared.Enum.Attachment_UpperRailType.HoloSight:
                        pvFov = GetCurrentWeapon().WeaponOption.PvZoom1HoloFOV;
                        break;
                    case CFA.Shared.Enum.Attachment_UpperRailType.DotSight:
                        pvFov = GetCurrentWeapon().WeaponOption.PvZoom1DotFOV;
                        break;
                    case CFA.Shared.Enum.Attachment_UpperRailType.Scope2x:
                        pvFov = GetCurrentWeapon().WeaponOption.PvZoom12XFOV;
                        break;
                    case CFA.Shared.Enum.Attachment_UpperRailType.Scope4x:
                        pvFov = GetCurrentWeapon().WeaponOption.PvZoom14XFOV;
                        break;
                }
            }
            else
            {
               pvFov = GetCurrentWeapon().WeaponOption.PvFOV;
            }
        }
        else
        {
            pvFov = 60;
        }
        return pvFov;
    }
    /// <summary>
    /// 락 걸어서 pv 동작 안하게 할떄 true
    /// </summary>
    /// <returns></returns>
    bool IsMoveLocked()
    {
        if ( ((Property.MoveDir & (int)Direction.Foward) != 0) && ((Property.MoveDir & (int)Direction.Back) != 0))
        {
            if (((Property.MoveDir & (int)Direction.Left) != 0) || ((Property.MoveDir & (int)Direction.Right) != 0))
                return false;
            return true;
        }
        else if(((Property.MoveDir & (int)Direction.Right) != 0) && ((Property.MoveDir & (int)Direction.Left) != 0))
        {
            if (((Property.MoveDir & (int)Direction.Foward) != 0) || ((Property.MoveDir & (int)Direction.Back) != 0))
                return false;
            return true;
        }
        return false;
    }
    /// <summary>
    /// 이동 실제 동작. 
    /// </summary>
    /// <param name="moveDir">이동 방향</param>
    void ActMove(int moveDir, bool forced = false)
    {
        //Debug.Log("ActMove:" + moveDir + ":" + forced + " : " + Property.IsRush);

        if (!ContinueProcess()) return;
        if (Property.IsDead) return;
        if ( Property.IsGroggyCare)
        {
            //Debug.Log("1");
            return;
        }
            
        //if (Property.IsZipLine) return;

        Property.MoveDir = moveDir;

        var weapon = _inventory.GetCurrentWeapon();
        if(weapon == null)
            return;
        
        //Debug.LogFormat("Left : {0}, Right : {1}, Forward : {2}, Backward : {3} "
        //    ,(Property.MoveDir & (int)Direction.Left) != 0, (Property.MoveDir & (int)Direction.Right) != 0,
        //    (Property.MoveDir & (int)Direction.Foward) != 0, (Property.MoveDir & (int)Direction.Back) != 0);
        //Debug.LogFormat("MoveLocked : {0} {1}", Property.MoveDir, Property.IsInAir);
        if (Property.IsInAir == false)
        {

            //if (((Property.MoveDir & (int)Direction.Foward) != 0 || (Property.MoveDir & (int)Direction.Back) != 0 || (Property.MoveDir & (int)Direction.Left) != 0 || (Property.MoveDir & (int)Direction.Right) != 0)
            //    && (((Property.MoveDir & (int)Direction.Foward) != 0 && (Property.MoveDir & (int)Direction.Back) != 0) && ((Property.MoveDir & (int)Direction.Left) != 0 || (Property.MoveDir & (int)Direction.Right) != 0))
            //    && (((Property.MoveDir & (int)Direction.Left) != 0 && (Property.MoveDir & (int)Direction.Right) != 0) && ((Property.MoveDir & (int)Direction.Foward) != 0 || (Property.MoveDir & (int)Direction.Back) != 0)))
            if(Property.MoveDir != 0 )
            {
                if (Property.IsGroggy)
                {//그로기 상태에서의 이동
                    //Debug.Log("2");
                    if (!character.IsPlayerDownAnimationWorks())
                        character.AnimateDownMove();
                }
                else
                {
                    //Debug.Log("3");
                    if (Property.IsSit)
                    {//앉은 상태에서의 이동
                        if (!Property.IsSliding)
                        {
                            //Debug.Log("1 : " + Property.IsReload);
                            if (!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady && !Property.IsSkillReady && !Property.IsThrowReserved && !Property.IsSkillReserved
                                && !IsMoveLocked())
                                character.AnimateSitMovePV(forced);
                            else
                            {
                                if (!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady && !Property.IsSkillReady && !Property.IsThrowReserved && !Property.IsSkillReserved && !character.IsPVIdleAnimationWorks())
                                    character.AnimatePVIdle(Property.IsSit);
                            }

                            //Debug.Log("4");
                            character.AnimateSitMoveQV();
                        }
                    }
                    else
                    {//서있는 상태에서의 이동
                        if (Property.IsRush)
                        {// 러쉬 중의 이동
                            if ((moveDir & (int)Direction.Foward) != 0)
                            {//
                                if(!Property.IsZipLine)
                                    DoRush(true);
                            }
                            else
                            {
                                if (!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady 
                                    && !Property.IsSkillReady && !Property.IsThrowReserved && !Property.IsSkillReserved
                                    && !IsMoveLocked())
                                    character.AnimateStandMovePV(forced);
                                else
                                {
                                    if (!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady && !Property.IsSkillReady && !Property.IsThrowReserved && !Property.IsSkillReserved && !character.IsPVIdleAnimationWorks())
                                        character.AnimatePVIdle(Property.IsSit);
                                }
                                character.AnimateStandMoveQV();
                            }
                        }
                        else//러쉬 없을때 이동. 
                        {
                            //Debug.Log("Move." + Property.IsInAir + "." + forced + "." + Property.IsInAir);
                            //Debug.Log("5 : " + Property.IsReload);
                            if (!Property.IsSliding)
                            {
                                if (Property.IsUseSkill)
                                {
                                    var skill = _inventory.GetSavedSkill();
                                    if (skill != null && (skill.SkillTableID == (int) AxCharacterSkill.Boris_Bombardment
                                        || skill.SkillTableID == (int) AxCharacterSkill.Olga_FieldHeal
                                        || skill.SkillTableID == (int) AxCharacterSkill.Olga_Portal))
                                    {
                                        //Debug.Log("3");
                                        character.AnimateStandMoveQV();
                                    }
                                    else
                                    {
                                        if (!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady
                                            && !Property.IsSkillReady && !Property.IsThrowReserved &&
                                            !Property.IsSkillReserved
                                            && !IsMoveLocked())
                                            character.AnimateStandMovePV(forced);
                                        else
                                        {
                                            if (!Property.IsReload && !Property.IsUseItem &&
                                                !Property.IsThrowReady && !Property.IsSkillReady &&
                                                !Property.IsThrowReserved && !Property.IsSkillReserved && !character.IsPVIdleAnimationWorks())
                                                character.AnimatePVIdle(Property.IsSit);
                                        }

                                        if (!Property.IsZipLine)
                                            character.AnimateStandMoveQV();
                                    }
                                }
                                else if (Property.IsThrow && Property.IsThrowReady)
                                {
                                    // DO NOTHING 
                                    //Debug.Log("6");
                                    character.AnimateStandMoveQV();
                                }
                                else
                                {
                                    //Debug.Log("1" + Property.IsReload);
                                    if (!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady && !Property.IsSkillReady
                                        && !Property.IsThrowReserved && !Property.IsSkillReserved && !IsMoveLocked() 
                                        && !IsSniperFireEndAnimatonWorks() && !GetCurrentWeapon().IsWeaponHaveToPostArms)//여기 fireEnd 처리 
                                    {
                                        //Debug.Log("2" + Property.IsReload);
                                        character.AnimateStandMovePV(forced);
                                    }
                                    else
                                    {
                                        //Debug.Log("3" + Property.IsReload);
                                        if (!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady && !Property.IsSkillReady && !Property.IsThrowReserved && !Property.IsSkillReserved && !character.IsPVIdleAnimationWorks())
                                            character.AnimatePVIdle(Property.IsSit);

                                        if(GetCurrentWeapon() != null)
                                        {
                                            var magEntry = weapon.Data.Weapon_Magazine;
                                            if(magEntry != null && magEntry.Value.ReloadType > 0)
                                            {
                                                if (Property.IsReload)
                                                {
                                                    character.AnimateStandMovePV(forced);
                                                }
                                            }
                                        }
                                    }
                                    if(!Property.IsZipLine)
                                    {
                                        ////Debug.Log("7");
                                        character.AnimateStandMoveQV();
                                    }
                                        
                                }
                                
                            }
                            else//슬라이딩
                            {
                                if (!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady && !Property.IsSkillReady && !Property.IsThrowReserved && !Property.IsSkillReserved)
                                {
                                    if(!character.IsPVStatePlaying(AnimatorValues.state_PV_Base_Sliding))
                                        character.AnimateSliding();
                                }
                                    
                            }
                        }
                    }
                }
            }
            else
            {//이동 없음. 
                //Debug.LogFormat("DoMove {0} {1} {2} {3}", !Property.IsGroggy, !Property.IsReload, !Property.IsZipLine, !Property.IsGroggyCare);
                if (!Property.IsGroggy && !Property.IsReload && !Property.IsZipLine && !Property.IsGroggyCare)
                {
                    //Debug.Log("Property.IsReload : " + Property.IsReload);
                    if(Property.IsUseSkill)
                    {
                        var skill = _inventory.GetSavedSkill();

                        if (skill != null && (skill.SkillTableID == (int)AxCharacterSkill.Boris_Bombardment
                            || skill.SkillTableID == (int)AxCharacterSkill.Olga_FieldHeal
                            || skill.SkillTableID == (int)AxCharacterSkill.Olga_Portal))
                        {
                            if (Property.IsSkillReady)
                            {

                                //Debug.Log("7");
                                return;
                            }
                        }
                    }
                    if (Property.IsThrow && Property.IsThrowReady)
                    {
                        //Debug.Log("8");
                        return;
                    }
                    //Debug.LogFormat("9 : {0}, {1}, {2}, {3}, {4}, {5}, {6}", Property.IsReload, Property.IsUseItem, Property.IsThrowReady, Property.IsSkillReady,
                    //    Property.IsThrowReserved, Property.IsSkillReserved, character.IsArmsPostmotionAnimationWorks());

                    if (!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady && !Property.IsSkillReady &&
                        !Property.IsThrowReserved && !Property.IsSkillReserved && !character.IsArmsPostmotionAnimationWorks() ) //여기 firend처리 
                    {
                        //Debug.LogError("Herer : " + GetCurrentWeapon().IsWeaponHaveToPostArms);
                        character.AnimateIdle(Property.IsSit, 0);
                    }
                }
            }
        }
        else
        {//하늘에서 
            
            if (Property.IsSkyDive)
            {//스카이 다이빙중
                if (Property.IsGroggy )
                {
                    if (!character.IsPlayerDownAnimationWorks())
                        character.AnimateDownMove();
                }
                else
                {
                    character.AnimateSkyDiveMove();
                }
            }
        }


    }
