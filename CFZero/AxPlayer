        character.SetCameraTarget(val);
        SetHealEffectLayer(!val);

        On_HealEffect(false, 0, -1);
        if (val == true)
        {
            if (ScreenEffectManager.Instance != null)
            {
                if (Property.IsHide)
                {
                    ScreenEffectManager.Instance.PlayHideEffect();
                    AxCameraController.Singleton.PlayScreenEffect(AxScreenEffectManager.AxScreenEffect.Hide);
                }
                else
                {
                    ScreenEffectManager.Instance.StopHideEffect();
