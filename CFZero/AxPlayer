    IEnumerator PlayFootSoundCulling()
    {
        while (true)
        {
            if (Mathf.Approximately(Property.MoveHorizontal, 0.0f) && Mathf.Approximately(Property.MoveVertical, 0.0f))
            {
                yield return null;
                continue;
            }

            float playSpeed = 0.4f;
            
            if (Property.IsSit)
                playSpeed = 0.6f;
            else if (Property.IsRush)
                playSpeed = 0.26f;

            isLeft = !isLeft;
            character.PlayFootSound(CFA.Shared.Enum.FootSoundType.Normal, isLeft);

            yield return new WaitForSeconds(playSpeed);
        }
    }

