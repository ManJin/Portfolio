    /// <summary>
    /// ---시작시
    /// 1인칭만 손넣기 출력
    /// 3인칭은 바로 클라이밍 애니메이션 시작
    /// 손넣기 끝나면 3인칭 Show true 1인칭 Show fasle
    /// 
    /// ---종료시 
    /// 3인칭 Show false 1인칭 Show true
    /// 3인칭 Idle
    /// 1인칭 꺼내기 시작
    /// </summary>
    /// <param name="isStart"></param>
    public void Queue_Climb(bool isStart)
    {
        if (_inventory == null)
        {
            Debug.LogFormat("Climb Inventory is NULL");
            return;
        }
        if (isStart && actionQueue.Count != 0)
        {
            actionQueue.Clear();
        }

        climbWeapon = _inventory.GetCurrentWeapon();
        climbSkill = _inventory.GetCurrentSkill();
        
        if (climbWeapon == null)
        {
            Debug.LogFormat("Climb Weapon is NULL");
            return;
        }

        //Debug.Log("Queue_Climb " + isStart + " : " + Property.IsUseSkill + " : " + climbSkill);
        isClimb = isStart;
        if (isStart)
        {
            if (Property.IsReload)
            {
                Property.IsReload = false;
            }

            if (climbWeapon.IsReloading)
                climbWeapon.IsReloading = false;

            if (Property.IsThrow)
            {
                Property.IsThrow = false;
                Property.IsThrowReady = false;
                Property.IsThrowReserved = false;
            }
            if (Property.IsUseItem)
                Property.IsUseItem = false;

            character.SetQVLayerWeight(AnimatorValues.UpperLayer, 0f);

            if (!Property.IsUseSkill)
            {

                if (climbWeapon != null)
                {
                    character.SetPVBool(AnimatorValues.hash_NextStep_Arms_Postmotion, climbWeapon.IsWeaponHaveToPostArms);
                    character.SetQVBool(AnimatorValues.hash_NextStep_Arms_Postmotion, climbWeapon.IsWeaponHaveToPostArms);
                }

                character.AnimateUnArmsWeapon(climbWeapon, _inventory.GetCurrentSlot(), 200, 0, () => { Property.IsUnarms = true; }, () => { Property.IsUnarms = false; Dequeue(); });
            }
            else
            {
                if (climbSkill != null)
                    character.AnimateUnArmsSkill(climbSkill, climbWeapon, _inventory.GetCurrentSlot(), 200, 0, () => { Property.IsUnarms = true; }, () => { Property.IsUnarms = false; Dequeue(); });
            }

            if (!character.IsStatePlaying(AnimatorValues.state_QV_Base_Climbing))
                character.AnimateClimbing();

            if (Property.IsUseSkill)
            {
                Property.IsUseSkill = false;
                Property.IsSkillReady = false;
                Property.IsSkillReserved = false;
            }

            actionQueue.Enqueue(StartClimb);
        }
        else
        {
            character.SetQVLayerWeight(AnimatorValues.UpperLayer, 1f);

            if (Property.IsCameraTarget)
            {
                character.ShowQVBody(false);
                character.ShowPVHand(true);
            }

            if (!Property.IsUseSkill)
            {
                character.SlotToHand(climbWeapon);
                //카메라가 보고있는 플레이어라면 
                if (Property.IsCameraTarget)
                {
                    if (!IsSniperFireEndAnimatonWorks())
                    AxInGame.Singleton.OnSendChangeCurrentWeapon(WorldKey, climbWeapon.WorldKey);
                }

            }
            else//스킬이면
            {
                if (climbSkill == null)
                    return;

                if (Property.IsCameraTarget)
                {
                    climbSkill.ShowPV(true);
                    character.AttachPVSkill(climbSkill.PV);
                }
                character.AnimateArmsSkill(climbSkill, climbWeapon, climbWeapon.CurrentSlot, 200, 0f, () => { Property.IsArms = true; }, () => { Property.IsArms = false; });
            }
        }
    }
    void StartClimb()
    {
        //카메라가 보고있는 플레이어라면 해야 되지만 그게 아니라면 해줄 필요가 없음.. 
        if (!Property.IsCameraTarget)
        {
            if (!isClimb)
            {
                if (!Property.IsUseSkill)
                {
                    if (GetCurrentWeaponSlot() != WeaponSlot.Fourth_Melee)
                        character.AnimateArmsWeapon(_inventory, 200, 0f, () => { Property.IsArms = true; }, () => { Property.IsArms = false; });
                }
                else//스킬이면
                {
                    if (climbSkill == null)
                        return;
                    character.AnimateArmsSkill(climbSkill, climbWeapon, climbWeapon.CurrentSlot, 200, 0f, () => { Property.IsArms = true; }, () => { Property.IsArms = false; });
                }

            }
            return;
        }

        if (isClimb)
        {
            character.ShowPVHand(false);
            character.ShowQVBody(true);
        }
        else
        {
            character.ShowPVHand(true);
            character.ShowQVBody(false);
            if (!Property.IsUseSkill)
            {
                _inventory.GetCurrentWeapon().ShowPV(true);
                character.AnimateArmsWeapon(_inventory, 200, 0, () => { Property.IsArms = true; }, () => { Property.IsArms = false; });
            }
            else
            {
                _inventory.GetCurrentSkill().ShowPV(true);
                character.AttachPVSkill(_inventory.GetCurrentSkill().PV);
                character.AnimateArmsSkill(climbSkill, climbWeapon, climbWeapon.CurrentSlot, 200, 0f, () => { Property.IsArms = true; }, () => { Property.IsArms = false; });
            }
            //character.AttachPVWeapon(_inventory.GetCurrentWeapon().PVWeapon);
        }
    }
