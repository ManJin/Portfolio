    Queue<Action> actionQueue = new Queue<Action>();
    /// <summary>
    /// 스킬로 바꾸는 단계 까지만 합시다. 
    /// </summary>
    /// <param name="nextType"></param>
    public void Queue_ChangeSkill(int skillID, AxSkillType nextType, AxOperationType operationType, Action action)
    {
        if (actionQueue.Count != 0)
        {
            actionQueue.Clear();
        }

        var curWeapon = _inventory.GetCurrentWeapon();

        _inventory.SetCurrentWeapon(WeaponSlot.Skill);

        AxSkillItem skill = _inventory.GetSkill(nextType);
        AxWeapon weapon = _inventory.GetPrevWeapon();

        if (skill == null)
        {
            Debug.Log("No Next Skill");
            return;
        }
        if(weapon == null)
        {
            weapon = _inventory.GetWeapon(WeaponSlot.Fourth_Melee);
        }

        //Debug.Log("weapon : " + weapon + " : " + _inventory.GetPrevSlot());
        character.ClearArmsAction();

        _inventory.SetCurrentSkill(nextType);
        _inventory.SetSavedSkill(skill.SkillType);
        _inventory.SetSavedWeapon(weapon);
        

        if (ShotController != null)
        {
            ShotController.SetCurrentWeapon(skill);
        }
        character.ShowPVItem(false, -1);
        character.ShowQVItem(false, -1);
        //Debug.Log("Queue_ChangeSkill : " + weapon.CurrentSlot + " : " + GetPrevWeaponSlot());
        Property.IsUseSkill = true;
        //Debug.Log("Queue_ChangeSkill " + operationType);

        if (Property.IsCameraTarget)
        {
            character.SetPVBool(AnimatorValues.hash_NextStep_SkillCancel, false);
        }

        if (curWeapon != null)
        {
            character.SetPVBool(AnimatorValues.hash_NextStep_Arms_Postmotion, curWeapon.IsWeaponHaveToPostArms);
            character.SetQVBool(AnimatorValues.hash_NextStep_Arms_Postmotion, curWeapon.IsWeaponHaveToPostArms);
        }
        
        switch (operationType)
        {
            case AxOperationType.NoAction:
                break;
            case AxOperationType.Instant://단발 애니메이션. 
                {//무기 내리고, 스킬 즉시 장착 이후 실행 호출
                    if (skillID == (int)AxCharacterSkill.Chase_InfraredSight || skillID == (int)AxCharacterSkill.Chase_Hide)
                    {
                        //Debug.Log("1111 : " + _inventory.GetPrevSlot());
                        if (_inventory.GetPrevSlot() != WeaponSlot.Fourth_Melee)
                        {
                            actionQueue.Enqueue(
                                () =>
                                {
                                    if (!Property.IsUseItem)
                                    {
                                        character.AnimateUnArmsWeapon(weapon, weapon.CurrentSlot, 0, 0,
                                        () => { Property.IsUnarms = true; },
                                        () =>
                                        {
                                            Property.IsUnarms = false;
                                            Dequeue();
                                        });
                                    }

                                });
                        }
                        actionQueue.Enqueue(() => { character.SkillToHand(skill, weapon, weapon.CurrentSlot, action); });
                    }
                    actionQueue.Dequeue()();
                }
                break;
            case AxOperationType.ThrowWeapon:
            case AxOperationType.SummonObject:
                {//내리고 들어 
                    if (skillID == (int)AxCharacterSkill.Olga_Portal || skillID == (int)AxCharacterSkill.Olga_FieldHeal || skillID == (int)AxCharacterSkill.Boris_Bombardment)
                    {
                        //if (_inventory.GetPrevSlot() != WeaponSlot.Fourth_Melee)
                        //    actionQueue.Enqueue(() => character.AnimateUnArmsWeapon(weapon, weapon.CurrentSlot, 0, 0, () => { Property.IsUnarms = true; }, () => { Property.IsUnarms = false; Dequeue(); }));
                        actionQueue.Enqueue(() => character.AnimateArmsSkill(skill, weapon, weapon.CurrentSlot, 0, 0, () => { character.SetPVBool(AnimatorValues.hash_NextStep_Unarms, false); Property.IsArms = true; Dequeue(); }, () => { Property.IsArms = false; }));
                    }
                    actionQueue.Dequeue()();
                    character.SetPVBool(AnimatorValues.hash_NextStep_Unarms, true);
                }
                break;
            case AxOperationType.Toggle:
                {//3인칭 전환 후 무기 내리기 후 방패 즉시 장착 하고 
                    if (skillID == (int)AxCharacterSkill.Boris_EnergyShield)
                    {
                        //Debug.Log("_inventory.GetPrevSlot() : " + _inventory.GetPrevSlot());
                        //if (_inventory.GetPrevSlot() != WeaponSlot.Fourth_Melee)
                        //    actionQueue.Enqueue(() => character.AnimateUnArmsWeapon(weapon, weapon.CurrentSlot, 0, 0, () => { Property.IsUnarms = true; }, () => { Property.IsUnarms = false; Dequeue(); }));
                        actionQueue.Enqueue(() => { character.SkillToHand(skill, weapon, weapon.CurrentSlot, action); });
                    }
                    actionQueue.Dequeue()();
                }
                break;
        }


        for (int i = 0; i < DataTableManager.AX_SkillTable.GetEntry(skill.SkillTableID).AdditionalEffectIDsLength; i++)
        {
            AxAdditionalEffect AdditionalEffectID = (AxAdditionalEffect)DataTableManager.AX_SkillTable.GetEntry(skill.SkillTableID).AdditionalEffectIDs(i);
            switch (AdditionalEffectID)
            {
                case AxAdditionalEffect.Portal:
                    if (Property.IsCameraTarget)
                    {
                        character.PvSkillEffectOn();
                    }
                    break;
            }
        }
    }

