    /// <summary>
    /// 캐릭터 로드
    /// </summary>
    /// <returns></returns>
    public IEnumerator LoadCharacter(/*Action action*/)
    {
        var entry = DataTableManager.BR_Ingame_ItemTable.GetItemEntryFromItemType(DataTableBRItemType.AxCharacter,
            (item) => item.HasValue && (item.Value.LinkID == playerData.baseEntry.CharacterID));

        if (entry.HasValue)
        {
            var bundleName = DataTableManager.ItemTable.GetItemBundleName(entry.Value.Index);

            UnityEngine.Assertions.Assert.IsTrue(bundleName.HasContent());

            //캐릭터 로드 시작. 
            Debug.Log("LoadCharacter.playerData:" + playerData.baseEntry.CharacterID);
            //if (playerData != null) Debug.Log("LoadCharacter.playerData.pathEntry:" + playerData.pathEntry);
            //Debug.LogError("LoadCharacter.playerData.pathEntry.Base:" + playerData.pathEntry.Base);
            var request1 = ResourceLoader.Instance.Load<GameObject>(bundleName, playerData.pathEntry.Base);
            while (!request1.IsComplete)
                yield return null;
            //캐릭터 베이스 노드 로드 
            GameObject go = (GameObject)request1.LoadedAsset;
            character = go.GetComponent<AxCharacter>();

            //캐릭터 QV바디 로드
            //if (playerData != null) Debug.Log("LoadCharacter.playerData.pathEntry.QV:" + playerData.pathEntry.QV);
            var request = ResourceLoader.Instance.Load<GameObject>(bundleName, playerData.pathEntry.QV);
            while (!request.IsComplete)
                yield return null;

            go = (GameObject)request.LoadedAsset;
            AxQVBody qvBody = go.GetComponent<AxQVBody>();
            go.name = go.name.Remove(go.name.Length - 7).Trim();

            //캐릭터 PV 손 로드
            //if (playerData != null) Debug.Log("LoadCharacter.playerData.pathEntry.PVArm:" + playerData.pathEntry.PVArm);
            request = ResourceLoader.Instance.Load<GameObject>(bundleName, playerData.pathEntry.PVArm);
            while (!request.IsComplete)
                yield return null;
            go = (GameObject)request.LoadedAsset;
            AxPVHand pvHand = go.GetComponent<AxPVHand>();
            go.name = go.name.Remove(go.name.Length - 7).Trim();
            
            //지금은 이모트만 불러오지만 캐릭터 전체 사운드 프리팹으로 전환할 예정
            string soundPath = GetSoundPrefabPath(playerData.baseEntry.CharacterType);
            request = ResourceLoader.Instance.Load<GameObject>(soundPath, "");
            while (!request.IsComplete)
                yield return null;

            go = (GameObject)request.LoadedAsset;
            go.transform.parent = character.transform.Find("Sounds");

            //바디와 손 모델을 캐릭터에 접착 / 캐릭터에 무기 장착

            //애니메이션 세트 및 캐릭터 초기화 

            yield return null;
            //플레이어 초기화 종료 
            this.gameObject.name = Name;
            OnLoaded(qvBody, pvHand);

            //Debug.Log("LOADED CHARACTER DONE = " + Name);

            HitBox = GetComponentInChildren<CFA.World.Hit.AxHitBox>();
            HitBox.AttachHitBoxInfo(this);

            //Debug.Log("LOADED CHARACTER DONE = " + Name);

            character.A_Throw = Throw;
            character.A_Punch = Punch;

            initialize = true;
            //Debug.LogErrorFormat("플레이어 스킬 로딩 시작지점 Player={0}, Time={1}", Name, Time.realtimeSinceStartup);

            ///패시브 아이템 일단 제거 
            //스킬 아이템 세트 
            //var passiveSkillId = playerData.baseEntry.PassiveSkillID;
            //var passiveModelId = DataTableManager.AX_SkillTable.GetModelID(passiveSkillId);
            //AxItem passiveSkill = AxItemManager.CreateItem(passiveSkillId, passiveModelId, passiveSkillId);
            //DoInvenPickSkill(passiveSkill, AxSkillType.Passive);

            var activeSkillId = playerData.baseEntry.ActiveSkillID;
            var activeModelId = DataTableManager.AX_SkillTable.GetModelID(activeSkillId);
            AxItem activeSkill = AxItemManager.CreateItem(activeSkillId, activeModelId, activeSkillId);
            DoInvenPickSkill(activeSkill, AxSkillType.Active);

            var ultimateSkillId = playerData.baseEntry.UltimateSkillID;
            var ultimateModelId = DataTableManager.AX_SkillTable.GetModelID(ultimateSkillId);
            AxItem ultimateSkill = AxItemManager.CreateItem(ultimateSkillId, ultimateModelId, ultimateSkillId);
            DoInvenPickSkill(ultimateSkill, AxSkillType.Ultimate);

            character.OnIdleStart(
                () => {
                    ActMove(Property.MoveDir, false);

                    if (Property.IsReload)
                    {
                        Property.IsReload = false;
                    }

                });
        }
        else
        {
            Debug.LogErrorFormat("Not found character item data from BR_Ingame_ItemTable. [{0}]", playerData.baseEntry.CharacterID);
        }
    }

