    public void DoDirectionSet(int moveDir, float vertical, float horizontal)
    {
        if ((moveDir & (int)Direction.Foward) == 0 && (moveDir & (int)Direction.Back) == 0)
        {//앞, 뒤 없음
            CalculateAxis.SetMoveVerticalAxis(0, vertical);
        }
        else if ((moveDir & (int)Direction.Foward) == 0 && (moveDir & (int)Direction.Back) != 0)
        {//뒤 있음
            CalculateAxis.SetMoveVerticalAxis(-1, vertical);
        }
        else if ((moveDir & (int)Direction.Foward) != 0 && (moveDir & (int)Direction.Back) == 0)
        {//앞 있음
            CalculateAxis.SetMoveVerticalAxis(1, vertical);
        }
        else
        {
            CalculateAxis.SetMoveVerticalAxis(0, vertical);
        }

        if ((moveDir & (int)Direction.Left) == 0 && (moveDir & (int)Direction.Right) == 0)
        {//좌, 우 없음
            CalculateAxis.SetMoveHorizontalAxis(0, horizontal);
        }
        else if ((moveDir & (int)Direction.Left) == 0 && (moveDir & (int)Direction.Right) != 0)
        {//우 있음
            CalculateAxis.SetMoveHorizontalAxis(1, horizontal);
        }
        else if ((moveDir & (int)Direction.Left) != 0 && (moveDir & (int)Direction.Right) == 0)
        {//좌 있음
            CalculateAxis.SetMoveHorizontalAxis(-1, horizontal);
        }
        else
        {
            CalculateAxis.SetMoveHorizontalAxis(0, horizontal);
        }

        character.SetDirection(vertical, horizontal);
        //character.AnimateStandMove();
    }
