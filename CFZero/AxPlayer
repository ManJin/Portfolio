    /// <param name="val">TRUE 넘어가기 활성화, FALSE 넘어가기 비활성화</param>
    public void DoParkour(bool val)
    {
        if (!ContinueProcess()) return;

        if (Property.IsDead)
        {
            Debug.LogError("DoParkour.PlayerIsDEAD");
            return;
        }

        if (character == null)
        {
            Debug.LogError("DoParkour.CharacterIsNULL");
            return;
        }

        //Debug.Log("DoParkour " + val);

        if (Property.IsCameraTarget & val)
        {
            if(Property.ViewMode != CameraViewMode.PV)
            {
                SetCharacterViewMode(CameraViewMode.PV);
                AxCameraController.Singleton.CameraModeChange(CameraViewMode.PV);
            }
        }
        
        if (Property.IsUseSkill)
        {
            var skill = _inventory.GetSavedSkill();

            if(skill.SkillTableID == (int)AxCharacterSkill.Boris_Bombardment
                || skill.SkillTableID == (int)AxCharacterSkill.Olga_FieldHeal
                || skill.SkillTableID == (int)AxCharacterSkill.Olga_Portal)
            {

            }
            else
            {
                Property.IsSkillReady = false;
                Property.IsSkillReserved = false;
            }
        }

        if (Property.IsUseItem)
            Property.IsUseItem = false;

        var weapon = _inventory.GetCurrentWeapon();
        if (weapon != null)
        {
            character.SetPVBool(AnimatorValues.hash_NextStep_Arms_Postmotion, weapon.IsWeaponHaveToPostArms);
            character.SetQVBool(AnimatorValues.hash_NextStep_Arms_Postmotion, weapon.IsWeaponHaveToPostArms);
            if (weapon.IsWeaponHaveToPostArms)
            {
                //Debug.Log("SetPVState");
                character.SetPVState(AnimatorValues.BaseLayer, AnimatorValues.state_PV_Base_Arms_Postmotion);
            }
        }

        //Debug.LogErrorFormat("DoParkour_{0}_{1}", val, Property.IsClimbing);
        if (val)
        {
            Property.IsParkour = true;

            if (weapon != null)
            {
                if(!weapon.IsWeaponHaveToPostArms)
                    character.AnimatePreParkourmotion();
            }
            character.AnimateParkourStart();
        }
        else
        {
            Property.IsParkour = false;
            if (!Property.IsUseSkill)
                character.SlotToHand(_inventory);
            else
            {
                if(climbWeapon != null)
                {
                    character.SkillToHand(climbSkill, climbWeapon, climbWeapon.CurrentSlot, null);
                }
            }
            //if(!Property.IsReload)
                character.AnimateParkourEnd();
            
        }
        character.SetQVLayerWeight(AnimatorValues.UpperLayer, 1f);
        Eventer.EventParam_Parkour.IsParkour = Property.IsParkour;
        Eventer.SendEvent(AxPlayerEventType.Parkour, Eventer.EventParam_Parkour);
    }
