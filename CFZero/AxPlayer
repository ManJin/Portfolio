    public void CharacterModelOn()
    {
        if (character == null)
        {
            //Debug.Log("CharacterModelOn character is null."+Name);
            return;
        }

        if (IsCharacterModeOn)
        {
            //Debug.Log("CharacterModelOn IsCharacterModeOn."+Name);
            return;
        }

        //Debug.LogError("CharacterModelOn." + Name);

        character.ShowPVHand(Property.IsCameraTarget);

        var skill = _inventory.GetCurrentSkill();
        var weapon = _inventory.GetCurrentWeapon();

        character.ModelOn();

        if (skill == null)
		{
			if (weapon != null)
			{
				character.SlotToHand(_inventory);

				if (Property.IsUseItem || Property.IsUseSkill)
				{
					if (Property.IsCameraTarget)
					{
						weapon.ShowPV(false);
						AxCameraController.Singleton.SetPvFOV(CameraValues.ItemPVFov);
					}
				}
				else
				{
					if (Property.IsCameraTarget)
						AxCameraController.Singleton.SetPvFOV(GetWeaponPvFov(Property.IsZoom));
				}
			}

            if(Property.IsUseItem)
            {
                //Debug.LogFormat("Property.IsCameraTarget={0}, Property.UseItemType={1}", Property.IsCameraTarget, Property.UseItemType);
                if (Property.IsCameraTarget)
                    AxCameraController.Singleton.SetPvFOV(CameraValues.ItemPVFov);

                

                character.ShowPVItem(Property.IsCameraTarget, Property.UseItemType == 0 ? 0 : 1);
				character.ShowQVItem(!Property.IsCameraTarget, Property.UseItemType == 0 ? 0 : 1);

				character.ShowPVItem(false, Property.UseItemType == 0 ? 1 : 0);
				character.ShowQVItem(false, Property.UseItemType == 0 ? 1 : 0);
			}
			else
			{
				//Debug.Log("???????????????????");
				character.ShowPVItem(false, -1);
				character.ShowQVItem(false, -1);
			}
            
        }
        else
        {
            //character.ModelOn();

            character.SkillToHand(skill, weapon, weapon.CurrentSlot, null);

            if (skill.SkillTableID == (int)AxCharacterSkill.Boris_EnergyShield)
            {
                //Debug.Log("SKill : "  + skill.GetQVSkillEffect(3));
                if (skill.GetQVSkillEffect(3) != null)
                    skill.GetQVSkillEffect(3).SetActive(true);


                skill.AnimateSkillActiveLoop_Boris(0,0,0);
                character.AnimateSkillLoop();
                //DoToggleMotionSkillStart();
            }
                

            if (Property.IsCameraTarget)
                AxCameraController.Singleton.SetPvFOV(CameraValues.ItemPVFov);
        }

        //character.ModelOn();

        if (Property.IsHide)
        {
            if (AxPlayerManager.Singleton.IsMyTeam(GroupKey))
                character.QVMaterialFxPlay(MaterialEffectPlayer.EMaterialEffectType.AXSkillStealthQV, 100);
            else
                character.QVMaterialFxPlay(MaterialEffectPlayer.EMaterialEffectType.AXSkillStealthEnermy, 100);
        }

		character.SetAnimationSoundFunc(GetCurrentQVWeapon);
		character.SetAnimationItemSoundFunc();

		IsCharacterModeOn = true;
    }
    public void CharacterModelOff()
    {
        if (character == null)
            return;

        if (IsCharacterModeOn == false)
            return;

        //Debug.LogError("CharacterModelOff." + Name);

        //투시이펙트 재생중일때 모델 안끄게끔 
        //꺼버리면 벽뒤에있을때 투시중일때도 사라짐
        if (character.QVGetPlayingMaterialFx() != null)
        {
            var Fx = character.QVGetPlayingMaterialFx();
            if (Fx.IsTypeOf<MaterialEffectAXSkillInfraredSight>() == true)
            {
                return;
            }
        }

        if (Property.IsGroggyCareEnd)
        {
            Property.IsGroggyCare = false;
            Property.IsGroggyCareEnd = false;
            character.EnableAim(true);
            character.InitBodyRotate();
            character.SetQVLayerWeight(AnimatorValues.UpperLayer, 1f);


        }

        //Debug.LogError("CharacterModelOff."+Name);
        character.ModelOff();
        IsCharacterModeOn = false;
    }

