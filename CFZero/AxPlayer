    public void DoDamage(eBR_FIELD_DAMAGE_TYPE type, Vector3 hitPosition, Vector3 hitNormal, Vector3 shooterPosition, BRAudioEvent.EventType audioEventType, int hp, float damage, int weaponID)
    {
        if (!ContinueProcess()) return;
        if (Property.IsDead) return;
        SetHp(hp);
        if (hitPosition != Vector3.zero && hitNormal != Vector3.zero)
            FXManager.Instance.PlayBREffect("CFBR/Effects/Beshot/BR_EFFECT_HUMAN_HIT", null, FXFollowType.Fixed,
                    hitPosition, Quaternion.LookRotation(hitNormal, Vector3.up), Vector3.one);

        if (Property.IsCameraTarget == true)
        {
            ScreenEffectManager.Instance.PlayHitEffect();
        }
        if (Property.IsHide)
        {
            if (isHitHide == false)
            {
                StartCoroutine("HitHide");
            }
        }


        if (character != null)
            character.PlayAudioEvent(audioEventType);

        Eventer.EventParam_Damage.FlushValue();
        Eventer.EventParam_Damage.Type = type;
        Eventer.EventParam_Damage.HP = hp;
        Eventer.EventParam_Damage.damage = damage;
        Eventer.EventParam_Damage.audioEventType = audioEventType;
        Eventer.EventParam_Damage.weaponID = weaponID;
        Eventer.EventParam_Damage.PlayerPosition = transform.position;
        Eventer.EventParam_Damage.ShootPosition = shooterPosition;
        Eventer.EventParam_Damage.PlayerQuaternion = transform.rotation;

        Eventer.SendEvent(AxPlayerEventType.Damage, Eventer.EventParam_Damage);
    }

