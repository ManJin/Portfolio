    /// <param name="val">TRUE 전력질주 활성화, FALSE 전력질주 비활성화 </param>
    public void DoRush(bool val)
    {
        //Debug.Log("DoRush." + val);
        //Debug.Log("DoRush : " + val + " : " + Property.MoveDir  + " : " + ((Property.MoveDir & (int)Direction.Foward) != 0)
        //    + " : " + ((Property.MoveDir & (int)Direction.Back) != 0));
        if (!ContinueProcess())
        {
            return;
        }

        if (Property.IsReload)
        {
            //Debug.LogError("DoRush.IsReload");
            return;
        }

        if (val && (Property.MoveDir & (int)Direction.Foward) == 0)
        {
            //Debug.LogErrorFormat("DoRush.Dir/Spd {0}, {1}", Property.MoveDir, (int)Direction.Foward == 0);
            return;
        }
        if (Property.IsGroggy)
        {
            //Debug.LogError("DoRush.IsGroggy");
            return;
        }
        if (Property.IsDead)
        {
            //Debug.LogError("DoRush.PlayerIsDEAD");
            return;
        }
        if (Property.IsSliding)
        {
            //Debug.LogError("DoRush.IsSliding");
            return;
        }
        if (val && Property.IsInAir)
        {
            //Debug.LogError("DoRush.IsInAir");
            return;
        }
        if (val && Property.IsSit)
        {
            //Debug.LogError("DoRush.IsSit");
            return;
        }

        //Debug.LogFormat("DoRush.Do.{0}.{1}",val, Time.realtimeSinceStartup );

        SetRush(val);
       


        if (val && !Property.IsSliding && !Property.IsSit)
        {//러쉬 시도. 슬라이딩, 앉기 중에는 러쉬 안함. 
            character.AnimateRushPV();
            character.AnimateRushQV();
        }
        else
        {
            if (Property.MoveDir == 0
                || ((Property.MoveDir & (int)Direction.Foward) != 0 && (Property.MoveDir & (int)Direction.Back) != 0))
            {
                
                character.AnimateIdle(Property.IsSit, 0f);
            }
            else
            {
                if (Property.IsSit)
                {
                    if (!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady && !Property.IsSkillReady && !Property.IsThrowReserved && !Property.IsSkillReserved)
                        character.AnimateSitMovePV();
                    character.AnimateSitMoveQV();
                }
                else
                {

                    if(Property.IsSliding)
                    {
                        if(!character.IsPVStatePlaying(AnimatorValues.state_PV_Base_Sliding))
                            character.AnimateSliding();
                    }
                    else
                    {
                        //Debug.LogFormat(
                        //    "{0}, {1}, {2}, {3}, {4}, {5}",
                        //    Property.IsReload, 
                        //    Property.IsUseItem, 
                        //    Property.IsThrowReady, 
                        //    Property.IsSkillReady, 
                        //    Property.IsThrowReserved, 
                        //    Property.IsSkillReserved);

                        if (!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady && !Property.IsSkillReady 
                            && !Property.IsThrowReserved && !Property.IsSkillReserved)
                            character.AnimateStandMovePV();
                        if(!Property.IsZipLine)
                            character.AnimateStandMoveQV();
                    }
                }
            }
        }
    }
    /// <summary>
