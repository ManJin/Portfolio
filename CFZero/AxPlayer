    /// <param name="normalizedTime">애니메이션 시작 위치</param>
    public void DoFire(int nLength, float normalizedTime)
    {
        if (!ContinueProcess())
        {
            //Debug.Log("DoFire.Initialize FALED");
            return;
        }
        if (Property.IsDead)
        {
            //Debug.LogError("DoFire.PlayerIsDEAD");
            return;
        }
        if (IsSkillReady())
        {
            //Debug.Log("DoFire.IsSkillReady");
            return;
        }
        if (IsUsingSkills())
        {
            //Debug.Log("DoFire.SkillAnimationWorks");
            return;
        }
        var slot = GetCurrentWeaponSlot();
        var currentWeapon = GetCurrentWeapon();

        if (currentWeapon == null)
        {
            //Debug.Log("DoFire.GetCurrentWeapon is NULL");
            return;
        }

        if (slot == WeaponSlot.Fourth_Melee && character.IsPVWorks())
        {
            //Debug.Log("DoFire.IsPVWorks");
            return;
        }

        //Debug.Log("DoFire");
        if (Property.IsRush == true)
        {
            SetRush(false);
            ActMove(Property.MoveDir);
        }

        if (currentWeapon.Data.ShotType == AxWeaponShotType.BoltAction)
        {
            currentWeapon.IsWeaponHaveToPostArms = true;
            character.SetPVBool(AnimatorValues.hash_NextStep_Arms_Postmotion, currentWeapon.IsWeaponHaveToPostArms);
            character.SetQVBool(AnimatorValues.hash_NextStep_Arms_Postmotion, currentWeapon.IsWeaponHaveToPostArms);
        }

        character.SetQVLayerWeight(AnimatorValues.UpperLayer, 1f);
        character.Set_PunchPunc(slot);
            
        if (slot == WeaponSlot.Fourth_Melee)
        {
            if (Property.IsInAir)
            {
                character.AnimateJumpPunch(currentWeapon, nLength, normalizedTime);
                currentWeapon.PlayMeleeAttackSound(2);
            }
            else
            {
                character.AnimateFireWeapon(currentWeapon, nLength, normalizedTime);
                currentWeapon.PlayMeleeAttackSound(0);
            }
        }
        else
        {
            bool isSniperWeapon = currentWeapon.WeaponClass == CFW.Shared.Enum.WEAPONCLASS.WEAPON_CLASS_SNIPER;
            character.SetPVBool(AnimatorValues.hash_SniperShot, isSniperWeapon);
            character.SetQVBool(AnimatorValues.hash_SniperShot, isSniperWeapon);

            
            

            character.AnimateFireWeapon(currentWeapon, nLength, normalizedTime,
                () =>
                {
                    if (isSniperWeapon)
                    {
                        DoFireEnd(0, 0, null);
                    }
                        //character.AnimateFireEndWeapon(currentWeapon, 0, 0, null);
                });
            character.AnimateMuzzleEffect(currentWeapon, Property.IsZoom);
            currentWeapon.PlayFireSound();
        }

        Eventer.EventParam_Fire.Slot = slot;
        Eventer.EventParam_Fire.CurrentBulletCount = currentWeapon.CurrentAmmo;
        Eventer.SendEvent(AxPlayerEventType.Fire, Eventer.EventParam_Fire);
        OffHideEffect();
        //Debug.Log("DoFire");
    }

