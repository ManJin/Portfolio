    void CheckAdditionalSkill(int SkillTableID)
    {
        //Debug.Log("CheckAdditionalSkill : " + SkillTableID);
        for (int i = 0; i < DataTableManager.AX_SkillTable.GetEntry(SkillTableID).AdditionalEffectIDsLength; i++)
        {
            AxAdditionalEffect AdditionalEffectID = (AxAdditionalEffect)DataTableManager.AX_SkillTable.GetEntry(SkillTableID).AdditionalEffectIDs(i);
            switch (AdditionalEffectID)
            {
                case AxAdditionalEffect.PenetratePlayer:
                    if (Property.IsCameraTarget)
                    {
                        AxEffectObjectManager.EffectResource effectResource = AxEffectObjectManager.Singleton.GetSkillEffectPath(CharID, eAxSkillEffectType.Active);
                        //"CFA/Effects/Skill/AX_EFFECT_SKILL_INFRAREDSIGHT_1RD";
                        string EffectName = SkillEffectPath.GetSkillEffectPath(effectResource.EffectResource_2);

                        //"CFA/Effects/Skill/AX_EFFECT_SKILL_INFRARESIGHT_FINGER";
                        string fingerEffectName = SkillEffectPath.GetSkillEffectPath(effectResource.EffectResource_3);

                        FXManager.Instance.PlayBREffect(EffectName, transform, FXFollowType.Fixed, transform.position, AxCameraController.Singleton.transform.rotation, Vector3.one);
                        FXManager.Instance.PlayBREffect(fingerEffectName, character.GetLFingerNode(), FXFollowType.ParentFollow, character.GetLFingerNode().position, Quaternion.identity, Vector3.one);
                    }
                    character.SetAnimate1MotionSkill(delegate
                    {
                        AxEffectObjectManager.Singleton.PlayRedSightEffect(CharID, transform.position, transform.forward,this.WorldKey, GroupKey, (int)AdditionalEffectID);

                    }
                    , 0.43f);

                    PlayAudioEvent(BRAudioEvent.EventType.Skill_ScanShoot);
                    break;

                case AxAdditionalEffect.HidePlayer:
                    {
                        if (Property.IsCameraTarget)
                        {
                            //FXManager.Instance.PlayBREffect("CFA/Effects/Skill/AX_EFFECT_SKILL_INVISIBLE_1RD", transform, FXFollowType.Fixed, transform.position, AxCameraController.Singleton.transform.rotation, Vector3.one);
                            AxEffectObjectManager.EffectResource effectResource = AxEffectObjectManager.Singleton.GetSkillEffectPath(CharID, eAxSkillEffectType.Ultimate);
                            //"CFA/Effects/Skill/AX_EFFECT_SKILL_INVISIBLE_FINGER";
                            string EffectName = SkillEffectPath.GetSkillEffectPath(effectResource.EffectResource_1);

                            FXManager.Instance.PlayBREffect(EffectName, character.GetRForearmNode(), FXFollowType.ParentFollow, character.GetRForearmNode().position, character.GetRForearmNode().rotation, Vector3.one);

                            PlayAudioEvent(BRAudioEvent.EventType.Skill_HideBegin);
                            PlayAudioEvent(BRAudioEvent.EventType.Skill_HideLoop);
                        }
                        if (IsCharacterModeOn == true)
                        {
                            character.SetAnimate1MotionSkill(delegate
                            {
                                Property.IsHide = true;

                                float HideLifeTime = DataTableManager.AX_AdditionalTable.GetEffectEntry((int)AdditionalEffectID).Value.LifeTime * 0.001f;

                                StopCoroutine("OffHide");
                                StartCoroutine("OffHide", HideLifeTime);


                                if (AxPlayerManager.Singleton.IsMyTeam(GroupKey))
                                    character.QVMaterialFxPlay(MaterialEffectPlayer.EMaterialEffectType.AXSkillStealthQV, HideLifeTime);
                                else
                                    character.QVMaterialFxPlay(MaterialEffectPlayer.EMaterialEffectType.AXSkillStealthEnermy, HideLifeTime);


                                if (Property.IsCameraTarget == true)
                                {
                                    AxCameraController.Singleton.PlayScreenEffect(AxScreenEffectManager.AxScreenEffect.Hide);
                                    character.PVMaterialFxPlay(MaterialEffectPlayer.EMaterialEffectType.AXSkillStealthPV, HideLifeTime);
                                    ScreenEffectManager.Instance.PlayHideEffect();
                                }
                            }
                             , 0.66f);
                        }
                        else
                        {
                            Property.IsHide = true;
                            float HideLifeTime = DataTableManager.AX_AdditionalTable.GetEffectEntry((int)AdditionalEffectID).Value.LifeTime * 0.001f;
                            StopCoroutine("OffHide");
                            StartCoroutine("OffHide", HideLifeTime);
                        }


                    }
                    break;
                case AxAdditionalEffect.Portal:
                    if (Property.IsCameraTarget)
                    {
                        AxEffectObjectManager.EffectResource effectResource = AxEffectObjectManager.Singleton.GetSkillEffectPath(CharID, eAxSkillEffectType.Ultimate);
                        //"CFA/Effects/Skill/AX_EFFECT_SKILL_PORTAL_1RD";
                        string EffectName = SkillEffectPath.GetSkillEffectPath(effectResource.EffectResource_2);

                        FXManager.Instance.PlayBREffect(EffectName, transform, FXFollowType.Fixed, transform.position, AxCameraController.Singleton.transform.rotation, Vector3.one);
                        character.PvSkillEffectOff();
                    }
                    break;
                case AxAdditionalEffect.Shield:
                    if (Property.IsCameraTarget)
                    {
                        Eventer.SendEvent(AxPlayerEventType.ToggleSkillStart, Eventer.EventParam_ToggleSkillStart);
                    }
                    var currentSkill = _inventory.GetCurrentSkill();
                    if(currentSkill != null)
                    {
                        currentSkill.AnimateSkillActiveStart_Boris(0, 0, 0);
                        var act = currentSkill.GetQVSkillAction();
                        if(act != null)
                            act.Action_Start();
                    }
                    else
                    {
                        Debug.LogErrorFormat("No Current Skill Player = {0}, SkillID = {1}", Name, SkillTableID );
                    }
                    character.EnableAim(false);
                    break;
            }

        }
    }

    void CheckAdditionalSkillEnd(AxSkillItem skill)
    {
        if (skill == null)
            return;

        var Entry = DataTableManager.AX_SkillTable.GetEntry(skill.SkillTableID);

        for (int i = 0; i < Entry.AdditionalEffectIDsLength; i++)
        {
            AxAdditionalEffect AdditionalEffectID = (AxAdditionalEffect)Entry.AdditionalEffectIDs(i);
            switch (AdditionalEffectID)
            {
                case AxAdditionalEffect.Shield:
                    skill.AnimateSkillActiveEnd_Boris(0, 0, 0);
                    if (skill.GetQVSkillEffect(3) != null)
                        skill.GetQVSkillEffect(3).SetActive(false);
                    
                    PlayAudioEvent(BRAudioEvent.EventType.Skill_ShieldEnd);
                    StopAudioEvent(BRAudioEvent.EventType.Skill_ShieldLoop);
                    break;
            }
        }
    }


