    public void DoRecvReloadEnd(long weaponKey, long magazineKey, short bulletCount, short chargeCount, bool cancel)
    {//
        if (!ContinueProcess()) return;

        if (Property.IsDead)
        {
            Debug.LogError("DoRecvReloadEnd.PlayerIsDEAD");
            return;
        }

        var weapon = _inventory.GetCurrentWeapon();
        if (weapon == null)
        {
            Debug.LogError("DoRecvReloadEnd.weapon is null");
            return;
        }
            
        if (weapon.Data == null || weapon.Data.Weapon_Magazine.HasValue == false)
        {
            Debug.LogError("DoRecvReloadEnd.weaponData is null");
            return;
        }

        //Debug.LogErrorFormat("DoRecvReloadEnd wepon = {0}, mag = {1}, bulletCount = {2}, chargeCount = {3}, isCancel = {4}"
        //    , weaponKey, magazineKey, bulletCount, chargeCount, cancel);


        if (cancel)
        {//cancel 로 들어옴.. 

            character.ReloadCancel();

            if (weapon.Data.Weapon_Magazine.HasValue == true)
			{
                weapon.IsReloading = false;
                if (weapon.Data.Weapon_Magazine.Value.ReloadType == 0)
				{
                    //Debug.LogFormat("DoRecvReloadEnd wepon = {0}, ReloadAni = {1}, ArmAni = {2}, ", weapon.ID, character.IsReloadAnimationWorks(), character.IsArmsAnimationWorks());
                    if (!character.IsArmsAnimationWorks())
                    {
                        character.AnimateReloadCancel(Property.IsSit);
                    }
				}
				else
                {
					character.AnimateReloadEndWeapon(weapon, 0, 0);
				}
			}
            else
            {
                Debug.LogErrorFormat("DoRecvReloadEnd No Magazine Data {0}", weapon.ID);
                return;
            }

            character.SetPVBool(AnimatorValues.hash_Reload, false);
        }
        else
        {
            SetWeaponAmmo(weapon.WorldKey, chargeCount);
            
            var magazine = _inventory.GetItem(magazineKey);
            if (magazine == null)
            {
                Debug.LogErrorFormat("DoRecvReloadEnd No Magazine {0}", magazineKey);
                return;
            }

            _inventory.RemoveItem(magazineKey, magazine.ID, magazine.Count - bulletCount, true);
                
            Eventer.EventParam_ReloadEnd.MagazineCount = magazine ? _inventory.GetItemCountInBag(magazine.ID) : 0;
            Eventer.EventParam_ReloadEnd.WeaponWorldKey = weaponKey;
            Eventer.EventParam_ReloadEnd.CurrentBulletCount = chargeCount;
            Eventer.EventParam_ReloadEnd.Slot = GetCurrentWeaponSlot();
            Eventer.SendEvent(AxPlayerEventType.ReloadEnd, Eventer.EventParam_ReloadEnd);

            if (weapon.Data.Weapon_Magazine.Value.ReloadType == 1)
            {//샷건
                //Debug.LogErrorFormat("DoRecvReloadEnd 3MotionReload.{0}.{1}.{2}.{3}", weapon.CurrentAmmo, weapon.MaxAmmo, chargeCount, magazine.Count);
                if (weapon.CurrentAmmo != weapon.MaxAmmo && chargeCount != 0 && Eventer.EventParam_ReloadEnd.MagazineCount != 0)
                {
                    if(WorldKey == AxPlayerManager.Singleton.MyPlayer.WorldKey)
                    {
                        weapon.IsReloading = true;
                        Property.IsReload = true;
                        AxInGame.Singleton.OnSendReloadStart();
                    }
                }
                else
                {
                    character.SetPVBool(AnimatorValues.hash_Reload, false);
                    character.AnimateReloadEndWeapon(weapon, 0, 0);
                }
            }
            else
            {
                character.SetPVBool(AnimatorValues.hash_Reload, false);
                Property.IsReload = false;
                weapon.IsReloading = false;
            }
        }

        if(Property.IsCameraTarget)
        {
            if(Property.KeyboardInputMoveDirState != 0)
                ActMove(Property.KeyboardInputMoveDirState);
            else
                ActMove(Property.MoveDir);
        }
        else
            ActMove(Property.MoveDir);
    }

