    /// <param name="id"></param>
    /// <returns></returns>
    AxItemType ReturnWeaponSlot(int id)
    {
        int tableVal = DataTableManager.BR_WeaponTable.GetWeapon(id).Slot(0);
        //Debug.Log("ReturnWeaponSlot." + id + "." + tableVal);
        if (tableVal == 0 || tableVal == 1 || tableVal == 2)
            return AxItemType.Weapon;
        else if (tableVal == 3 || tableVal == 5)
            return AxItemType.Melee;
        else if (tableVal == 4)
            return AxItemType.Throw;
        return AxItemType.None;
    }
