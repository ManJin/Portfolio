    /// <summary>
    /// 에너지 쉴드 
    /// </summary>
    public void DoEnergyShield(bool enable, float currentEnergy,float MaxEnergy)
    {
        if (Property.MaxEnergyShieldPoint == 0)
        {
            Property.MaxEnergyShieldPoint = MaxEnergy;
            //Debug.Log("Property.MaxEnergyShieldPoint == 0");
        }

        Property.EnergyShieldPoint = currentEnergy;

        var skill = _inventory.GetSavedSkill();

        if (skill == null)
            return;
        if (skill.SkillTableID != (int)AxCharacterSkill.Boris_EnergyShield || skill.GetQVSkillAction() == null)
            return;
        for (int i = 0; i < 4; i++)
            if (skill.GetQVSkillEffect(i) == null)
                return;

        float result = currentEnergy / Property.MaxEnergyShieldPoint;

        if (enable == true)
        {
            if (result < 0.5 && result >= 0.3)
            {
                if (skill.GetQVSkillEffect(0).activeSelf == false)
                {
                    ShieldSkillEffectSet(skill, 0);
                    PlayAudioEvent(BRAudioEvent.EventType.Skill_ShieldCrack);
                }
            }
            else if (result < 0.3 && result >= 0.01)
            {
                if (skill.GetQVSkillEffect(1).activeSelf == false)
                {
                    ShieldSkillEffectSet(skill, 1);
                    PlayAudioEvent(BRAudioEvent.EventType.Skill_ShieldCrack);
                }
            }
            else if (result <= 0)
            {
                if (skill.GetQVSkillEffect(2).activeSelf == false)
                {
                    ShieldSkillEffectSet(skill, 2);
                    PlayAudioEvent(BRAudioEvent.EventType.Skill_ShieldBreak);
                }
            }
        }
        else
        {
            if (result <= 0)
            {
                skill.GetQVSkillAction().Action_End();
                ShieldSkillEffectSet(skill, 2);
                PlayAudioEvent(BRAudioEvent.EventType.Skill_ShieldBreak);
            }
            else
            {
                ShieldSkillEffectSet(skill, 3);
            }
        }
        skill.GetQVSkillEffect(3).SetActive(enable);

        Eventer.EventParam_EnergyShield.Enable = enable;
        Eventer.EventParam_EnergyShield.Progress = Property.MaxEnergyShieldPoint != 0f ? result : 0f;
        
        Eventer.SendEvent(AxPlayerEventType.EnergyShield, Eventer.EventParam_EnergyShield);
    }

    void ShieldSkillEffectSet(AxSkillItem skill, int num)
    {
        for(int i=0;i<3;i++)
        {
            if(i==num)
                skill.GetQVSkillEffect(i).SetActive(true);
            else
                skill.GetQVSkillEffect(i).SetActive(false);
        }
    }

    

