    {
        if (actionQueue.Count != 0)
        {
            actionQueue.Clear(); 
        }
        AxWeapon currentWeapon = _inventory.GetCurrentWeapon();
        WeaponSlot slot = _inventory.GetCurrentSlot();
        _inventory.SetCurrentWeapon(WeaponSlot.Item);
