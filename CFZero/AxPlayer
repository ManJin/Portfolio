    /// <param name="val">TRUE 슬라이딩 활성화, FALSE 슬라이딩 비활성화</param>
    public void DoSlide(bool val, bool sitKeyHasPressed = false)
    {
        if (!ContinueProcess()) return;
        if (Property.IsGroggy) return;
        //if (val && Property.IsReload) return;
        if (Property.IsDead)
        {
            //Debug.LogError("DoSlide.PlayerIsDEAD");
            return;
        }

	    Eventer.EventParam_Slide.val = val;
	    Eventer.SendEvent(AxPlayerEventType.Slide, Eventer.EventParam_Slide);

        if (Property.IsSliding == val)
        {
            //Debug.LogError("DoSlide.SameState");
            return;
        }

        if (Property.IsRush)
	    {
	        SetRush(false);
        }
        character.SetQVLayerWeight(AnimatorValues.UpperLayer, 1f);
        Property.IsSliding = val;
        character.SetPVBool(AnimatorValues.hash_Slide, val);
        //Debug.Log("DoSlide." + val + "." + Property.MoveDir + "." + Property.IsSit + " : " + sitKeyHasPressed + " : " + character.IsPVStatePlaying(AnimatorValues.state_PV_Base_Sliding));
        character.SetPVLayerWeight(AnimatorValues.SitLayer, 1);
        if (val == true)
        {
            if (sitKeyHasPressed)
                character.AnimateSitToSlide();
            else
                character.AnimateStandToSlide();

            if(!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady && !Property.IsSkillReady && !Property.IsThrowReserved && !Property.IsSkillReserved
                && !character.IsSingleMotionSkill() && !character.IsPVStatePlaying(AnimatorValues.state_PV_Base_Sliding))
                character.AnimatePVSliding();

            character.PlaySlideStartSound();
            
            //Property.IsSit = true;
            character.SetPVBool(AnimatorValues.hash_Sit, true);
            //character.SetPVLayerWeight(AnimatorValues.SitLayer, 1);
            StartCoroutine(PlaySlideEffect());
        }
        else
        {
            if (Property.MoveDir == 0)
            {
                if (sitKeyHasPressed)
                    character.AnimateSlideToSit();
                else
                    character.AnimateSlideToStand();
                    
            }
            else
            {
                if (sitKeyHasPressed)
                {
                    if (!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady && !Property.IsSkillReady && !Property.IsThrowReserved && !Property.IsSkillReserved
                         && !character.IsSingleMotionSkill())
                        character.AnimateSitMovePV();
                    character.AnimateSlideToSit();
                }
                else
                {
                    if (!Property.IsReload && !Property.IsUseItem && !Property.IsThrowReady && !Property.IsSkillReady && !Property.IsThrowReserved && !Property.IsSkillReserved
                         && !character.IsSingleMotionSkill())
                        character.AnimateStandMovePV();
                    character.AnimateSlideToStand();
                }
            }
            //Property.IsSit = false;
            character.SetPVBool(AnimatorValues.hash_Sit, false);
            //character.SetPVLayerWeight(AnimatorValues.SitLayer, 0);
        }

    }

    
    IEnumerator PlaySlideEffect()
    {
        int Maphitmask = CFA.Util.AxPhysicsUtil.MapMaterialCheckLayer;
        while (Property.IsSliding)
        {
            yield return new WaitForSeconds(0.1f);
            if (((Property.IsCameraTarget && AxCameraController.Singleton.GetCurrViewMode() != CameraViewMode.PV)
                || !Property.IsCameraTarget) && Property.IsHide==false)
            {
                RaycastHit hit;
                if (Physics.Raycast(transform.position+new Vector3(0,5f,0), Vector3.down, out hit, 10f, Maphitmask))
                {

                    CFW.Physics.MaterialType material = MapCollision.GetMaterialCollision(hit.collider, hit.point);

                  //Debug.Log(material);

                    string effectName = "CFA/Effects/AX_EFFECT_HUMAN_SLIDE_STONE";

                    if (material == CFW.Physics.MaterialType.WATER)
                    {
                        effectName = "CFA/Effects/AX_EFFECT_HUMAN_SLIDE_WATER";
                    }
                    else if (material == CFW.Physics.MaterialType.METAL)
                    {
                        effectName = "CFA/Effects/AX_EFFECT_HUMAN_SLIDE_METAL";
                    }

                    FXManager.Instance.PlayBREffect(effectName,
                        null, FXFollowType.Fixed, character.GetDummySlide().transform.position, transform.rotation, Vector3.one);
                }
            }

        }
        StopCoroutine(PlaySlideEffect());
    }


