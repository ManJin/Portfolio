    /// <summary>
    /// 무기 선택한 경우
    /// </summary>
    /// <param name="id">무기 테이블 ID</param>
    /// <param name="slot">선택된 무기 슬롯 </param>
    /// <param name="nLength">애니메이션 테이블에서의 해당 모션 길이</param>
    /// <param name="normalizedTime">애니메이션 시작위치</param>
    public void DoWeaponSelect(long worldKey, bool fromSkill, Action onSelected)
    {
        if (!ContinueProcess())
        {
            //Debug.LogErrorFormat("DoWeaponSelect.Initialize FALED : {0} : {1} ({2}, {3})", Name, worldKey, character, initialize);
            return;
        }
        if (Property.IsDead)
        {
            //Debug.LogErrorFormat("DoWeaponSelect.PlayerIsDEAD : {0}", Name);
            return;
        }
        var prevSlot = _inventory.GetCurrentSlot();
        if (_inventory.SetCurrentWeapon(worldKey) == false)
        {
            //Debug.LogErrorFormat("DoWeaponSelect.SetCurrentWeapon FALED : {0} : {1}", Name, worldKey);
            return;
        }
        if (ShotController == null)
        {
            //Debug.LogErrorFormat("DoWeaponSelect.ShotController Is Null : {0}", Name);
            return;
        }
        var weapon = _inventory.GetWeapon(worldKey);// GetCurrentWeapon();
        if (weapon == null)
        {
            //Debug.LogErrorFormat("DoWeaponSelect Is Null : {0}", Name);
            return;
        }

        weapon.IsReloading = false;
        

        Property.IsThrow = false;
        Property.IsThrowReady = false;
        Property.IsThrowReserved = false;

        Property.IsUseSkill = false;
        Property.IsSkillReady = false;
        Property.IsSkillReserved = false;


        if (Property.IsGroggyCare)
        {
            if (!(AxInGame.Singleton is AxInGameTutorial))
            {
                Property.IsGroggyCare = false;
                Property.IsGroggyCareEnd = true;
                character.EnableAim(true);
                character.InitBodyRotate();
                character.SetQVLayerWeight(AnimatorValues.UpperLayer, 1f);
            }
        }
        //Debug.LogError("WeaponSelect : " + weapon.Name + " : " + weapon.CurrentSlot + " : " +weapon.PVWeapon.gameObject.GetInstanceID());

        if (!Property.IsGroggy && !Property.IsGroggyCare && !Property.IsZipLine)
            character.SetQVLayerWeight(AnimatorValues.UpperLayer, 1f);
        else
            character.SetQVLayerWeight(AnimatorValues.UpperLayer, 0f);
        //
        ShotController.SetCurrentWeapon(weapon.CurrentSlot); //<- 이큅웨폰 에서 초기 Shot 모드 지정함. 
        
        int slot = (int)weapon.CurrentSlot;// GetCurrentWeaponSlot();

        Action onPlaySound_Arms = () =>
        {
            if (slot >= 0 && slot < 5)
                PlayAudioEvent(BRAudioEvent.EventType.EquipSlot1 + slot);
        };
        Action onPlaySound_UnArms = () =>
        {
            if (slot >= 0 && slot < 5)
                PlayAudioEvent(BRAudioEvent.EventType.UnequipSlot1 + slot);
        };

        var prevWeapon = _inventory.GetPrevWeapon();

        if (prevWeapon != null)
        {
            prevWeapon.IsReloading = false;
            prevWeapon.ChangeState(prevWeapon.CurrentSlot == WeaponSlot.Fifth_Throw ? AxItem.State.HandGrenadeToEquipGrenade : AxItem.State.EquipWeapon, Property.IsCameraTarget);
        }


        weapon.ChangeState(AxItem.State.Hand, Property.IsCameraTarget);

        _calcZoomTypeAxis.SetLerpTime(DataTableManager.AX_AnimationTable.GetZoomInOutSpeed(weapon.ModelID));
        
        //Debug.Log("@@@@@@@@ : " + weapon.ModelID + " : " + DataTableManager.AX_AnimationTable.GetZoomInOutSpeed(weapon.ModelID));
        if (weapon.IsLoadedCharacterWeaponModel() == true)
        {//일로 들어왔습니다. 
            Queue_ChangeWeapon(prevWeapon, weapon, prevSlot
                , () =>
                {
                    if (Property.IsRush)
                        character.SetQVLayerWeight(AnimatorValues.UpperLayer, 0f);
                    if (onSelected != null)
                        onSelected();
                    //Debug.Log("WeaponSelect End");
                },
                onPlaySound_Arms, onPlaySound_UnArms, fromSkill);
        }
        else//
        {
            StartCoroutine(weapon.StateChangeAfterLoaded(AxItem.State.Hand,
                () => Queue_ChangeWeapon(prevWeapon, weapon, prevSlot,
                    () =>
                    {
                        if (Property.IsRush)
                            character.SetQVLayerWeight(AnimatorValues.UpperLayer, 0f);
                        if (onSelected != null)
                            onSelected();
                        //Debug.Log("WeaponSelect End");
                    }, onPlaySound_Arms, onPlaySound_UnArms, fromSkill), Property.IsCameraTarget));
        }

        AxItem magazine = _inventory.GetItemByID((int)weapon.MagazineItemID);
        Property.IsUseItem = false;

        //Debug.Log("Weapon."+weapon + " : " +weapon.ShotMode + " : " + ShotController.GetCurrentFiringMode());
        
        if (weapon.ShotMode != FiringModeType.None)
        {
            ShotController.SetCurrentFiringMode(weapon.ShotMode);
        }
        else
        {
            weapon.ShotMode = ShotController.GetCurrentFiringMode();
        }   

        Eventer.EventParam_WeaponSelect.WeaponData.Set(weapon, this);
        Eventer.EventParam_WeaponSelect.BagBulletCount = magazine != null ? magazine.Count : 0;
        Eventer.EventParam_WeaponSelect.FiringModeType = ShotController.GetCurrentFiringMode();
        Eventer.SendEvent(AxPlayerEventType.WeaponSelect, Eventer.EventParam_WeaponSelect);
    }

