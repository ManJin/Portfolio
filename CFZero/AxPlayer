                    var oldParts = _inventory.PartsEquip(item as AxWeaponParts, equipSlot);
	                if (oldParts != null)
	                {
		                oldParts.Destroy();
	                }


                }
                else
                {
                    var weapon = item as AxWeapon;
                    //Debug.Log("무기가 장착됩니다. = "+ item.ID + " : " + item.ModelID);
                    if (weapon != null)
                    {
                        WeaponEquip(weapon, equipSlot, false);
                        StartCoroutine(weapon.StateChangeAfterLoaded(AxItem.State.EquipWeapon, () => {  OnCompleteWeaponEquip(weapon, equipSlot, onEquipComplete); },Property.IsCameraTarget) );
                    }
                    else
                    {
                        Debug.LogErrorFormat("장착될 무기가 없음! = " + item);
                    }
                }
                break;
            case eBATTLEGROUND_EQUIP.eBG_INVENTORY_EQUIP:
                //Debug.Log("그냥 가방으로");
                _inventory.AddToBag(item);
                return;
            default:
                Debug.LogErrorFormat("이상한게 왔어요 ID={0}, equipPos={1}", item.ID, equipPosition);
