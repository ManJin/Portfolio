    public void SetCharacterViewMode(CameraViewMode mode)
    {
        //Debug.Log("SetCharacterViewMode " + mode + " : " + Name + " : " + Property.IsUseItem);
        Property.ViewMode = mode;

        if (mode == CameraViewMode.PV)
        {
            character.ShowPVHand(true);
            var skill = _inventory.GetCurrentSkill();
            if (skill)
            {
                skill.ShowPV(Property.IsCameraTarget);
                skill.ShowQV(false);
            }
            else
            {
                if (Property.IsUseItem)
                {
                    character.ShowPVItem(Property.IsCameraTarget, Property.UseItemType);
                    character.ShowQVItem(!Property.IsCameraTarget, Property.UseItemType);
                }
                else
                {
                    var currentweapon = _inventory.GetCurrentWeapon();
                    HideAllPVWeapon();

                    if (currentweapon)
                    {
                        currentweapon.ShowPV(true);
                        character.AttachPVWeapon(currentweapon);
                    }
                }
            }

            for (int i = 0; i < (int)WeaponSlot.Skill; i++)
            {
                var weapon = _inventory.GetWeapon((WeaponSlot)i);
                if (weapon)
                {
                    weapon.ShowQV(false);
                }
            }

            character.ShowQVBody(false);


            SetHealEffectLayer(false);
        }
        else//QV 로변경시 
        {


            character.ShowPVHand(false);
            var skill = _inventory.GetCurrentSkill();
            if (skill)
            {
                skill.ShowPV(false);
                skill.ShowQV(true);
            }
            else
            {
                if (Property.IsUseItem)
                {
                    character.ShowPVItem(false, Property.UseItemType);
                    character.ShowQVItem(true, Property.UseItemType);
                }

                HideAllPVWeapon();

                var currentweapon = _inventory.GetCurrentWeapon();
                if (currentweapon)
                {
                    if (currentweapon.CurrentSlot == WeaponSlot.First_Rifle || currentweapon.CurrentSlot == WeaponSlot.Second_Rifle)
                        currentweapon.ShowQV(true);
                    else
                        currentweapon.ShowQV(false);
                }
            }

            for (int i = 0; i < (int)WeaponSlot.Skill; i++)
            {
                var weapon = _inventory.GetWeapon((WeaponSlot)i);
                if (weapon)
                {
                    if ((WeaponSlot)i == WeaponSlot.First_Rifle || (WeaponSlot)i == WeaponSlot.Second_Rifle)
                        weapon.ShowQV(true);
                    else
                        weapon.ShowQV(false);
                }
            }

            character.ShowQVBody(true);
            SetHealEffectLayer(true);

        }

    }
