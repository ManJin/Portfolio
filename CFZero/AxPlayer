    [SerializeField]
    float distanceCanHear = 5.0f;
    Vector2 vec2From = new Vector2();
    Vector2 vec2To = new Vector2();
    public void PlayBulletPassSound(AxPlayer _Shooter, Quaternion _bulletDirection)
    {
		if (_Shooter == null)
		{
			Debug.LogError("_shooter = null");
			return;
		}

        Transform shootersMuzzle = _Shooter.NeckObj;

        if (shootersMuzzle == null)
        {
            Debug.LogError("shootersMuzzle = null");
            return;
        }

        Transform myHead = NeckObj;

        shootersMuzzle.rotation = _bulletDirection;
        Vector3 bulletDirection = shootersMuzzle.forward;
        Vector3 shooterToMeDirection = (myHead.position - shootersMuzzle.position).normalized;

        float distance = Vector3.Distance(shootersMuzzle.position, myHead.position);
        float angleMeAndBullet = Vector3.Angle(bulletDirection, shooterToMeDirection);
        float gapMeAndBullet = distance * Mathf.Sin(angleMeAndBullet * Mathf.Deg2Rad);
        float distanceToSoundPos = gapMeAndBullet / Mathf.Tan(angleMeAndBullet * Mathf.Deg2Rad);

        Vector3 soundPos = shootersMuzzle.position + (bulletDirection * distanceToSoundPos);
        Vector3 soundDir = soundPos - myHead.position;

#if UNITY_EDITOR
        Debug.DrawRay(shootersMuzzle.position, shooterToMeDirection * distance, Color.green, 5);

        Debug.DrawLine(shootersMuzzle.position, soundPos, Color.red, 5);
#endif

        bool isPlaySound = true;
        bool isLeftSound = true;
        RaycastHit hit;
        if (gapMeAndBullet <= distanceCanHear && angleMeAndBullet < 90)
        {
            if (Physics.Raycast(shootersMuzzle.position, bulletDirection, out hit, distance + 5, ShotController.HitMask) == true)
            {
                float angleMeAndHitedBullet = Vector3.Angle(bulletDirection, (myHead.position - hit.point).normalized);
                if (angleMeAndHitedBullet >= 90)
                    isPlaySound = true;
                else
                    isPlaySound = false;
            }
            else
                isPlaySound = true;

            if (isPlaySound == true)
            {
                vec2From.x = soundDir.x;
                vec2From.y = soundDir.z;
                vec2To.x = transform.forward.x;
                vec2To.y = transform.forward.z;
                float signedAngle = Vector2.SignedAngle(vec2From, vec2To);
                isLeftSound = signedAngle < 0 ? true : false;

                if (isLeftSound == true)
                    character.PlayAudioEvent(BRAudioEvent.EventType.WhizLeft);
                else
                    character.PlayAudioEvent(BRAudioEvent.EventType.WhizRight);
            }
        }

        shootersMuzzle.rotation = Quaternion.identity;
    }

