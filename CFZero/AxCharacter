    /// <summary>
    /// 지정된 슬롯을 핸드로 
    /// </summary>
    /// <param name="slot"></param>
    public void SlotToHand(AxInventory target)
    {
        //Debug.Log("SlotToHand." + target );
        if (target == null || pv == null || qv == null)
            return;
        
        AxWeapon current = target.GetCurrentWeapon();

        if(current == null ||  current.PVWeapon == null || current.QVWeapon == null)
        {
            Debug.LogError("GetCurrentWeapon is NULL");
            return;
        }

        List<AxWeapon> others = target.GetOtherWeapon();

        //ShowPVItem(false, -1);
        //ShowQVItem(false, -1);

        for (int i = 0; i < others.Count; i++)
        {
            if (others[i] == null || others[i].PVWeapon == null || others[i].QVWeapon == null)
                continue;

            others[i].ShowPV(false);
            
            pv.DettachWeapon(others[i].PVWeapon.transform);

            if (others[i].CurrentSlot == WeaponSlot.First_Rifle || others[i].CurrentSlot == WeaponSlot.Second_Rifle)
                qv.ToBack(others[i].QVWeapon.transform, (int)others[i].CurrentSlot);
            else
                others[i].ShowQV(false);
        }

        if (isCameraTargetedCharacter)
        {
            if (!axProperty.IsGroggy && !axProperty.IsClimbing)
                current.ShowPV(true);

            AttachPVWeapon(current);
        }
        else
        {
            current.ShowPV(false);
            
            if (current.CurrentSlot == WeaponSlot.First_Rifle || current.CurrentSlot == WeaponSlot.Second_Rifle)
            {
                current.ShowQV(true);
            }
            else
                current.ShowQV(false);
        }


        if (pv != null && current.PVWeapon != null)
        {
            pv.ToHand(AxAttachNode.RightHand, current.PVWeapon.transform);
        }
            

        if (qv != null && current.QVWeapon != null)
        {
            qv.ToHand(AxAttachNode.RightHand, current.QVWeapon.transform);
        }

        ArmsWeapon(current);

        //Debug.LogFormat("SlotToHand.{0}={1}, {2}={3}", 
        //    target.GetCurrentWeapon().WorldKey, target.GetCurrentWeapon().transform.localRotation,
        //    target.GetPrevWeapon().WorldKey, target.GetPrevWeapon().transform.localRotation);
    }
