    public void AnimateForceIdle(bool standType)
    {

        float standVal = 0.0f;
        if (standType)
            standVal = 1.0f;
        else
            standVal = 0.0f;

        //Debug.Log(("AnimateForceIdle " + standType ));

        SetQVFloat(AnimatorValues.hash_StandType, standVal);
        CrossFadePV_ms(AnimatorValues.state_PV_Base_Idle, 0.1f, AnimatorValues.BaseLayer, 0f, 0.1f, 0f, 0f);
        CrossFadeQV_ms(AnimatorValues.state_QV_Upper_Aimming, 0.1f, AnimatorValues.UpperLayer, 0f, 0.1f, 0f, 0f);
        CrossFadeQV_ms(AnimatorValues.state_QV_Base_Idle, 0.1f, AnimatorValues.BaseLayer, 0f, 0.1f, 0f, 0f);
    }
