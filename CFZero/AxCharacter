    {
        //Debug.Log("AnimatePVIdle : "+ Name);
        float standVal = 0.0f;
        if (standType)
            standVal = 1.0f;
        else
            standVal = 0.0f;

        SetQVFloat(AnimatorValues.hash_StandType, standVal);

        if (!IsPVWorks())
