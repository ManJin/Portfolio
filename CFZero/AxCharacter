    IEnumerator LoadItem()
    {
        var syringItem = DataTableManager.BR_Ingame_ItemTable.GetItem(2601001);
        string syringeName = DataTableManager.AX_AnimationTable.GetNodeName(2601001);

        var pdaItem = DataTableManager.BR_Ingame_ItemTable.GetItem(2601003);
        string pdaName = DataTableManager.AX_AnimationTable.GetNodeName(2601003);

        string syringBundleName = DataTableManager.ItemTable.GetItemBundleName(syringItem.Index);

        UnityEngine.Assertions.Assert.IsTrue(syringBundleName.HasContent());

        var request = ResourceLoader.Instance.Load<GameObject>(syringBundleName, syringItem.InGameModelPV);

        //Debug.LogError("Load : " + syringItem.InGameModelPV);
        while (!request.IsComplete)
            yield return null;

	    GameObject go = (GameObject) request.LoadedAsset;
        AxPVConsumable syringePV = go.GetComponent<AxPVConsumable>();
        syringePV.name = syringeName;
        AttachPVMaterialFxAttacher(syringePV.GetComponent<MaterialEffectAttacher>());

        request = ResourceLoader.Instance.Load<GameObject>(syringBundleName, syringItem.InGameModelQV);
        while (!request.IsComplete)
            yield return null;

	    go = (GameObject) request.LoadedAsset;
        AxQVConsumable syringeQV = go.GetComponent<AxQVConsumable>();
        syringeQV.name = syringeName;
        AttachQVMaterialFxAttacher(syringeQV.GetComponent<MaterialEffectAttacher>());

        string pdaBundleName = DataTableManager.ItemTable.GetItemBundleName(pdaItem.Index);

        UnityEngine.Assertions.Assert.IsTrue(pdaBundleName.HasContent());

        request = ResourceLoader.Instance.Load<GameObject>(pdaBundleName, pdaItem.InGameModelPV);
        while (!request.IsComplete)
            yield return null;

	    go = (GameObject) request.LoadedAsset;
        AxPVConsumable pdaPV = go.GetComponent<AxPVConsumable>();
        pdaPV.name = pdaName;
        AttachPVMaterialFxAttacher(pdaPV.GetComponent<MaterialEffectAttacher>());

        request = ResourceLoader.Instance.Load<GameObject>(pdaBundleName, pdaItem.InGameModelQV);
        while (!request.IsComplete)
            yield return null;

	    go = (GameObject) request.LoadedAsset;
        AxQVConsumable pdaQV = go.GetComponent<AxQVConsumable>();
        pdaQV.name = pdaName;
        AttachQVMaterialFxAttacher(pdaQV.GetComponent<MaterialEffectAttacher>());

        LoadedConsumableItem(syringePV, syringeQV, pdaPV, pdaQV);
        yield return 0;
    }

    void LoadedConsumableItem(AxPVConsumable syringePV, AxQVConsumable syringeQV, AxPVConsumable pdaPV, AxQVConsumable pdaQV)
    {
        AxConsumable syringe = new AxConsumable();
        syringe.Initialize(2601001, 2601001, "Syring");
        syringe.SetObject(syringePV, syringeQV);
        arrayConsumable[0] = syringe;
        ItemToHand(AxAttachNode.RightHand, 0);
        ShowPVItem(false, 0);
        ShowQVItem(false, 0);


        AxConsumable pda = new AxConsumable();
        pda.Initialize(2601003, 2601003, "PDA");
        pda.SetObject(pdaPV, pdaQV);
        arrayConsumable[1] = pda;
        ItemToHand(AxAttachNode.RightHand, 1);
        ShowPVItem(false, 1);
        ShowQVItem(false, 1);

        SetAnimationItemSoundFunc();

    }
