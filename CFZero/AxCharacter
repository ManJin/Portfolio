    IEnumerator gustFadeIn = null;
    IEnumerator gustFadeOut = null;
    float windGustVolume = 1.0f;

    public void PlayWindGustSound(float velocityY)
    {
        float windVelocity = GlobalAmbientAudio.singleton.windGust_VelocityY;
        float fadeInTime = GlobalAmbientAudio.singleton.windGust_FadeInTime;
        float fadeOutTime = GlobalAmbientAudio.singleton.windGust_FadeOutTime;

        if (velocityY >= windVelocity && gustFadeIn == null)
            return;

        if (velocityY <= windVelocity && gustFadeIn == null)
        {
            if(gustFadeOut != null)
            {
                StopCoroutine(gustFadeOut);
                gustFadeOut = null;
            }

            windGustVolume = _windGustAudio.volume;
            gustFadeIn = PlaySoundFadeIn(_windGustAudio, fadeInTime);
            StartCoroutine(gustFadeIn);
        }
        else if (velocityY >= windVelocity && gustFadeOut == null)
        {
            if(gustFadeIn != null)
            {
                StopCoroutine(gustFadeIn);
                gustFadeIn = null;
            }

            _windGustAudio.volume = windGustVolume;
            gustFadeOut = PlaySoundFadeOut(_windGustAudio, fadeOutTime, true);
            StartCoroutine(gustFadeOut);
        }
    }

    public IEnumerator PlaySoundFadeIn(AudioSource audioSource, float FadeTime)
    {
        float startVolume = audioSource.volume;
        audioSource.volume = 0;
        audioSource.enabled = true;
        audioSource.Play();
        
        while (audioSource.volume < startVolume)
        {
            audioSource.volume += startVolume * Time.deltaTime / FadeTime;
            yield return null;
        }
    }

    public IEnumerator PlaySoundFadeOut(AudioSource audioSource, float FadeTime, bool isPause = false)
    {
        float startVolume = audioSource.volume;
        while (audioSource.volume > 0)
        {
            audioSource.volume -= startVolume * Time.deltaTime / FadeTime;
            yield return null;
        }

        if (isPause)
            audioSource.Pause();
        else
            audioSource.Stop();

        audioSource.enabled = false;
        audioSource.volume = startVolume;
    }

