    public void AttachWeapon(AxItem item, WeaponSlot slot, bool isCameraTarget)
    {
        if (slot <= WeaponSlot.None && slot >= WeaponSlot.EndofType)
        {
            Debug.LogErrorFormat("AttachWeapon : {0}", slot);
            return;
        }

        if (item == null)
        {
            Debug.LogErrorFormat("AttachWeapon : Item is NULL");
            return;
        }

        AxWeapon weapon = item as AxWeapon;
        weapon.ShowPV(false);

        AttachPVWeapon(weapon);

        if (qv != null && weapon.QVWeapon != null)
            qv.ToBack(weapon.QVWeapon.transform, (int)slot);
        if(slot == WeaponSlot.First_Rifle || slot == WeaponSlot.Second_Rifle)
            weapon.ShowQV(!isCameraTarget);
        else
            weapon.ShowQV(false);
    }
