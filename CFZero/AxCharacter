    public void Initialize(AxPVHand hand, AxQVBody body, string name, bool isUI = false)
    {
        if (!isUI)
        {
            if (pv == null || qv == null) return;

            Name = name;

            if (hand != null)
                pv.SetPVHand(hand);

                pv.InitializeEffectEventPlayer();

            if (body != null)
            {
                qv.SetBody(body);
                _dieEffect = body.GetComponent<BRCharacterDissolveEffectPlayer>();
            }

            pv.ShowHand(!isUI);
            qv.ShowBody(isUI);

            InitializeAnimator();

            StartCoroutine("LoadItem");

            StartCoroutine("LoadJetPack");

            StartCoroutine("LoadZipLineTool");
            //여기에 아이템 주사기, PDA 두개 로드해서 들고 있을것.... 
        }
        else
        {
            //Debug.LogError("UI INITIALIZE");
            if (qv == null) return;
            qv.SetBody(body);
            EnableAim(false);
            qv.SetLobbyAnimator();
            qv.InitializeUIDictionary();
            //body.GetComponent<CFA.World.Hit.AxHitBox>().EnableCollider(false);
        }

        _audioEvent = transform.GetComponentsInChildren<BRAudioEvent>();
        if(_audioEvent != null && _audioEvent.Length > 0)
            _audioEvent[0].transform.parent.parent = transform; // 컬링시에 캐릭터 모델이 꺼지기 때문에 사운드 transform을 상단으로 올림

        _windGustAudio.enabled = false;
    }

