            reloadState.ActEnd = null;
        else
            Debug.LogErrorFormat("GetStateBehaviour reloadState is NULL");

        int reloadVal = target.GetAnimationLength().Reload;

        if (_AniLengthTest)
            reloadVal = target.GetTestLength().Reload;
        //Debug.Log("AnimateReloadWeapon : "+ onEnd);
