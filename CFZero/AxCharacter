    public void ModelOn( )
    {
        if (pv == null || qv == null || axProperty == null)
            return;

        //Debug.Log("ModelOn." + Name + " : " + axProperty.IsGroggyCare + " : " + axProperty.IsGroggyCareEnd);
        pv.ModelOn();
        qv.ModelOn();

        if (axProperty.IsGroggyCareEnd)
            axProperty.IsGroggyCare = false;

        if (axProperty.IsSkyDive)
        {
            if (!axProperty.IsSkyDiveSlowDown)
                AnimateSkyDiveMove(true);
            else
                AnimateSkyDiveSlowDown(true);
        }
        
        else if (axProperty.IsGroggy)// 그로기
        {
            if (axProperty.IsGroggyCare & !axProperty.IsGroggyCareEnd)
                AnimateGroggyCareTargetLoop();
            else
                AnimateDownMove();
        }
        else if (axProperty.IsGroggyCare & !axProperty.IsGroggyCareEnd)
        {
            AnimateGroggyCareActorLoop();
        }
        else if (axProperty.IsZipLine)// 집라인
        {
            AnimateZipLine();
        }
        else if (axProperty.IsUseItem)
        {
            if (axProperty.UseItemType == 0)
            {
                SetPVBool(AnimatorValues.hash_NextStep_UseItem, false);
                SetQVBool(AnimatorValues.hash_NextStep_UseItem, false);
                AnimateUseItemLoop();
            }
            else
            {
                SetPVBool(AnimatorValues.hash_NextStep_UsePDA, false);
                SetQVBool(AnimatorValues.hash_NextStep_UsePDA, false);
                AnimateUsePDALoop();
            }
        }
        else if (axProperty.MoveDir != 0)
        {
            if (axProperty.IsSit)
            {
                if(axProperty.IsSliding)
                {
                    if (!IsPVStatePlaying(AnimatorValues.state_PV_Base_Sliding))
                        AnimateSliding();
                }
                else
                {
                    AnimateSitMovePV();
                    AnimateSitMoveQV();
                }
                
            }
            else if (axProperty.IsRush)
            {
                AnimateRushPV();
                //AnimateRushQV();
                CrossFadeQV_ms(AnimatorValues.state_QV_Base_Rush, 0.1f, AnimatorValues.BaseLayer, 0f, 0.1f, 0, 0);
            }
            else
            {
                AnimateStandMovePV();
                //AnimateStandMoveQV()
                CrossFadeQV_ms(AnimatorValues.state_QV_Base_StandMove, 0.1f, AnimatorValues.BaseLayer, 0.1f, 0f, 0, 0);
            }
        }
       
