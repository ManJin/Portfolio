    MaterialType footSoundMaterial;

    public void PlayFootSound(FootSoundType type, bool bLeft)
    {
        RaycastHit hit;

        Vector3 rayDir = Vector3.down;
        if (type == FootSoundType.Climb)
            rayDir = transform.forward;

        if (Physics.Raycast(transform.position + Vector3.up, rayDir, out hit, 2f, MapCollision.HitMask))
        {
            BRMaterialSoundContainer.volumeMinMax vol;
            footSoundMaterial = MapCollision.GetMaterialCollision(hit.collider, hit.point);

            if (type == FootSoundType.Normal)
            {
                AudioClip clip = MapCollision.GetFootSoundByMaterial(footSoundMaterial, bLeft);
                vol = BRMaterialSoundContainer.Singleton.FootSoundVol;
                _PlayFootSound(clip, bLeft, vol);
            }
            else if(type == FootSoundType.Climb)
            {
                AudioClip clip = MapCollision.GetClimbSoundByMaterial(footSoundMaterial, bLeft);
                vol = BRMaterialSoundContainer.Singleton.ClimbSoundVol;
                _PlayFootSound(clip, bLeft, vol);
            }
            else
            {
                AudioClip clip = MapCollision.GetCrawlSoundByMaterial(footSoundMaterial, bLeft);
                vol = BRMaterialSoundContainer.Singleton.CrawlSoundVol;
                _PlayFootSound(clip, bLeft, vol);
            }
        }
    }

    private void _PlayFootSound(AudioClip clip, bool left, BRMaterialSoundContainer.volumeMinMax vol = null)
    {
        if (clip == null) return;

        float pitch;
        float volume;

        if(vol == null)
        {
            pitch = UnityEngine.Random.Range(0.95f, 1.05f);
            volume = UnityEngine.Random.Range(0.23f, 0.25f);
        }
        else
        {
            pitch = UnityEngine.Random.Range(vol.Pitch_Min, vol.Pitch_Max);
            volume = UnityEngine.Random.Range(vol.Vol_Min, vol.Vol_Max);
        }


        if (left)
        {
            _footSoundLeft.enabled = true;
            _footSoundLeft.volume = volume;
            _footSoundLeft.pitch = pitch;
            _footSoundLeft.PlayOneShot(clip);
        }
        else
        {
            _footSoundRight.enabled = true;
            _footSoundRight.volume = volume;
            _footSoundRight.pitch = pitch;
            _footSoundRight.PlayOneShot(clip);
        }

        PlayGearSound();
    }
