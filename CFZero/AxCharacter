    /// <param name="normalizedTime"></param>
    public void AnimateArmsWeapon(AxInventory inventory, int nLength, float normalizedTime, Action onStart = null, Action onEnd = null, Action onPlaySound = null)
    {
        if (qv == null || qv.QVBody == null || !qv.QVBody.isActiveAndEnabled) return;
        AxWeapon weapon = inventory.GetCurrentWeapon();
        if (weapon == null) return;
        //Debug.Log("AnimateSelectWeapon."+weapon );

        ClearReloadEndAction(weapon);
        

        if (isCameraTargetedCharacter && axProperty.ViewMode == CameraViewMode.PV)
        {
            ShowPVHand(true);
        }
        
        if (onPlaySound != null)
            onPlaySound();

        var armsState = qv.GetStateBehavior<AnimatorState_QV_Arms>(AnimatorValues.state_QV_Upper_Arms);

        if (armsState != null)
        {
            armsState.ActStart
            = () => {
                SlotToHand(inventory);
                if (onStart != null)
                    onStart.Invoke();
            };
        }
        else
            Debug.LogError("GetStateBehavior.ArmsState is NULL");

        if (armsState != null)
            armsState.ActEnd 
                = () =>
                {
                    if(onEnd != null)
                        onEnd.Invoke();
                };
        else
            Debug.LogError("GetStateBehavior.ArmsState is NULL");

        ThrowEnd();

        //Debug.Log("AnimateArmsWeapon : ");
        int val = weapon.GetAnimationLength().Armed;

        if (nLength != 0)
            val = nLength;

        if (_AniLengthTest)
            val = weapon.GetTestLength().Armed;

        if (isCameraTargetedCharacter)
            AxCameraController.Singleton.SetCurrentWeaponPvFov();

        PlayPV_ms(AnimatorValues.state_PV_Base_Arms, AnimatorValues.BaseLayer
            , normalizedTime, weapon.GetAnimationLength().Armed, val); //* arrayWeapon[currentSlot].AnimationLength_Calc[(int)StatPerformanceType.e23_ChangeSpeed]);
        //if (!isClimb)
        //CrossFadeQV_ms(AnimatorValues.state_QV_Upper_Arms, 0.0f, AnimatorValues.UpperLayer, normalizedTime, 0f, weapon.GetQVLength().Armed, nLength);

        PlayQV_ms(AnimatorValues.state_QV_Upper_Arms, AnimatorValues.UpperLayer
        , normalizedTime, weapon.GetQVLength().Armed, val); //* arrayWeapon[currentSlot].AnimationLength_Calc[(int)StatPerformanceType.e23_ChangeSpeed]);



    }
