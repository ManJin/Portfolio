    public class GameEventManager : Common.Utils.Coding.StaticInstance<GameEventManager>
    {
        #region Handler 기반 이벤트 처리

        private readonly GameEventEntry[] _events = new GameEventEntry[(int) GameEvent.Max];

        public void RegisterEvent(GameEventHandler handler, GameEvent gameEvent)
        {
            if (handler == null)
                return;

            GameEventEntry find = _events[(int) gameEvent];

            if (find == null)
            {
                GameEventEntry newEntry = new GameEventEntry {Event = gameEvent};
                newEntry.ListHandler.Add(handler);
                _events[(int) gameEvent] = newEntry;
            }
            else
            {
                for (int nCount = 0; nCount < find.ListHandler.Count; ++nCount)
                {
                    // 이미 등록된 핸들러임
                    if (find.ListHandler[nCount] == handler)
                        return;

                    // 이벤트를 등록한 주체인 Handler 가 소실된것 제거
                    if (find.ListHandler[nCount] == null)
                    {
                        find.ListHandler.RemoveAt(nCount);
                        --nCount;
                    }
                }

                find.ListHandler.Add(handler);
            }
        }

        public void UnRegisterEvent(GameEvent gameEvent, GameEventHandler handler)
        {
            GameEventEntry find = _events[(int)gameEvent];
            if (find != null)
                find.RemoveHandler(handler);
        }
        #endregion

        #region CallBack 기반 이벤트 처리 - delegate 호출시 Boxing / UnBoxing 에 의한 GC Alloc 발생함
        //Dictionary<GameEvent, GameEventCallBackEntry> _eventCallbacks = new Dictionary<GameEvent, GameEventCallBackEntry>();

        private readonly GameEventCallBackEntry[] _eventCallbacks = new GameEventCallBackEntry[(int) GameEvent.Max];

        public void RegisterEventCallBack(GameEvent gameEvent, GameEventCallBack callBack)
        {
            if (callBack == null)
                return;

            if (gameEvent <= GameEvent.UnKnownEvent || gameEvent >= GameEvent.Max)
                return;

            var find = _eventCallbacks[(int) gameEvent];
            if (find == null)
            {
                var newEntry = new GameEventCallBackEntry {Event = gameEvent};
                newEntry.AddCallBack(callBack);
                _eventCallbacks[(int) gameEvent] = newEntry;
            }
            else
            {
                find.AddCallBack(callBack);
            }
        }

        public void UnRegisterEventCallBack(GameEvent gameEvent, GameEventCallBack callBack)
        {
            if (callBack == null)
                return;

            var find = _eventCallbacks[(int) gameEvent];
            if ( find != null )
                find.RemoveCallBack(callBack);

            //if ( _eventCallbacks[(int)gameEvent] )
            //if (_eventCallbacks.TryGetValue(gameEvent, out find) == true)
            //    find.RemoveCallBack(callBack);
        }
        #endregion

        public void SendEvent(GameEvent gameEvent, IGameEventParam param)
        {
            var find = _events[(int) gameEvent];
            if (find != null)
                find.RaiseEvent(param);

            var eventCallBack = _eventCallbacks[(int) gameEvent];
            if (eventCallBack != null)
                eventCallBack.RaiseEvent(param);
        }

        public void SendEvent( GameEvent gameEvent , params object[] param )
		{
            var find = _events[(int)gameEvent];
            if (find != null)
                find.RaiseEvent(param);

